# Redirect OG share-card requests to the dedicated og.tightropetracker.uk Worker.
# The og:image meta tags and ShareGrid links now point directly to the OG Worker
# domain. This redirect is a safety net for any legacy links or crawlers that hit
# the /og/* path on the main domain.
/og/*  https://og.tightropetracker.uk/og/:splat  302
