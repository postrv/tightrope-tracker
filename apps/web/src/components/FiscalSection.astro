---
import type { PillarScore } from "@tightrope/shared";
import { OBR_TARGET_YEAR_LABEL } from "@tightrope/shared";
import { signedDelta, trendDescriptor } from "~/lib/format.js";
import { yFor, Y_AXIS_TICKS, IFS_CUSHION_BN, IFS_CUSHION_Y } from "~/lib/fiscalChart.js";
import IllustrativeBadge from "./IllustrativeBadge.astro";
import IndicatorTooltip from "./IndicatorTooltip.astro";

interface Props {
  pillar: PillarScore;
  /**
   * OBR cb_headroom vintages, latest first. The chart plots them oldest-
   * first along the x axis with the latest highlighted. When zero or one
   * vintage is present, the chart degrades to an empty-state hint (rather
   * than rendering a misleading single-point line).
   */
  headroomVintages?: ReadonlyArray<{ value: number; observedAt: string }>;
}

const { pillar, headroomVintages = [] } = Astro.props;

interface Round { label: string; value: number; colour: string; x: number; highlight?: boolean }

// Convert an OBR EFO publication date into a short label e.g. "Oct '24",
// "Mar '26". Heuristic only — March = Spring Forecast, Oct/Nov = Budget,
// but we don't tag those qualifiers in the label itself; the chart hint
// already names the source.
function shortVintageLabel(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "";
  const mon = d.toLocaleString("en-GB", { month: "short", timeZone: "UTC" });
  const yr2 = String(d.getUTCFullYear()).slice(-2);
  return `${mon} '${yr2}`;
}

// Plot the vintages oldest-first. We accept up to four; with fewer the
// x-axis still spans 110→470 evenly so the path doesn't compress weirdly.
const ordered = [...headroomVintages].reverse();
const xs = [110, 230, 350, 470];
const rounds: Round[] = ordered.slice(-4).map((v, i, arr) => ({
  label: shortVintageLabel(v.observedAt),
  value: v.value,
  colour: i === arr.length - 1 ? "var(--accent)" : "var(--band-steady)",
  x: xs[Math.max(0, xs.length - arr.length) + i] ?? xs[i] ?? 110,
  highlight: i === arr.length - 1,
}));

const chartHasData = rounds.length >= 2;
---
<section class="section" id="fiscal" aria-labelledby="fiscal-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Pillar 2 · 30%</span>
        <h2 class="sec-title" id="fiscal-title" style="margin-top: 14px;">Fiscal room</h2>
        <p class="section-sub">How much room the Chancellor actually has against her own stability rule, and how that has moved between forecast rounds.</p>
      </div>
      <div class="pillar-score" aria-label={`Fiscal pillar score ${Math.round(pillar.value)}`}>
        <span class="pillar-score-num">{Math.round(pillar.value)}</span>
        <span class="pillar-score-sub">/100</span>
        {(() => {
          const t30 = pillar.trend30d ?? "flat";
          const d30 = typeof pillar.delta30d === "number" ? pillar.delta30d : 0;
          const cls = t30 === "up" ? "up" : t30 === "down" ? "dn" : "flat";
          return (
            <span class={`pillar-score-delta ${cls}`} title="Change across the 30-day sparkline window (first to last point).">
              {t30 === "flat" ? "flat" : (
                <>
                  {t30 === "up" ? "▲" : "▼"} {signedDelta(d30, 1)}
                  {trendDescriptor(d30) ? <span class="trend-word"> {trendDescriptor(d30)}</span> : null}
                </>
              )} / 30d
            </span>
          );
        })()}
      </div>
    </div>

    <div class="fiscal-grid">
      <div class="chart-card">
        <div class="card-head">
          <h3>OBR forecast headroom for {OBR_TARGET_YEAR_LABEL}, by vintage</h3>
          <IllustrativeBadge
            sourceSummary="Each dot is the current-budget headroom figure from one OBR Economic and Fiscal Outlook publication, drawn straight from the live cb_headroom indicator (sourced via the obrEfo adapter). Updated automatically when a new EFO lands."
            sourceUrl="https://obr.uk/efo/"
          />
        </div>
        <p class="hint">£ billion, surplus against the stability rule at the {OBR_TARGET_YEAR_LABEL} target year. Each dot is a separate OBR forecast round.</p>
        {chartHasData ? (
          <svg class="chart" viewBox="0 0 600 240" preserveAspectRatio="none" role="img" aria-label="Current budget headroom over OBR forecast rounds">
            <defs>
              <linearGradient id="headFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="var(--accent)" stop-opacity="0.22"/>
                <stop offset="1" stop-color="var(--accent)" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <g stroke="var(--border-soft)" stroke-width="1">
              {Y_AXIS_TICKS.map((t) => <line x1="40" y1={t.gridY} x2="580" y2={t.gridY}/>)}
            </g>
            <g font-family="IBM Plex Mono" font-size="10" fill="var(--ink-2)">
              {Y_AXIS_TICKS.map((t) => <text x="32" y={t.labelY} text-anchor="end">{t.value}</text>)}
            </g>
            <g font-family="IBM Plex Mono" font-size="9.5" fill="var(--ink-2)">
              {rounds.map((r) => <text x={r.x - 30} y={234}>{r.label}</text>)}
            </g>

            <path
              d={(() => {
                const segments = rounds.map((r) => `${r.x} ${yFor(r.value)}`);
                const move = `M ${segments[0]}`;
                const lines = segments.slice(1).map((s) => `L ${s}`).join(" ");
                const close = `L ${rounds[rounds.length - 1]!.x} 220 L ${rounds[0]!.x} 220 Z`;
                return `${move} ${lines} ${close}`;
              })()}
              fill="url(#headFill)"
            />
            <path
              d={(() => {
                const segments = rounds.map((r) => `${r.x} ${yFor(r.value)}`);
                return `M ${segments[0]} ` + segments.slice(1).map((s) => `L ${s}`).join(" ");
              })()}
              stroke="var(--accent)" stroke-width="1.5" fill="none" stroke-linecap="round"
            />

            {rounds.map((r) => (
              <g>
                <circle cx={r.x} cy={yFor(r.value)} r={r.highlight ? 4.5 : 4} fill={r.colour} />
                <text x={r.x} y={yFor(r.value) - 12} text-anchor="middle" font-family="IBM Plex Mono" font-size={r.highlight ? 10.5 : 10} fill={r.colour} font-weight={r.highlight ? 500 : 400}>{r.value.toFixed(1)}</text>
              </g>
            ))}

            <line x1="40" y1={IFS_CUSHION_Y} x2="580" y2={IFS_CUSHION_Y} stroke="var(--band-critical)" stroke-width="1" stroke-dasharray="3 4" opacity="0.6"/>
            <text x="574" y={IFS_CUSHION_Y - 4} text-anchor="end" font-family="IBM Plex Mono" font-size="9.5" fill="var(--band-critical)" opacity="0.85">IFS prudent cushion · £{IFS_CUSHION_BN}bn</text>
          </svg>
        ) : (
          <p class="hint" style="font-style: italic; color: var(--ink-2); padding: 32px 0;">Awaiting at least two OBR vintages from the live feed before the comparison chart renders.</p>
        )}
      </div>

      <div class="chart-card">
        <div class="card-head">
          <h3>The <IndicatorTooltip label="DMO" description="UK Debt Management Office — the executive agency that issues gilts (UK government bonds) on behalf of HM Treasury. Its 'gilt stack' is the planned mix of new bonds it will sell over the financial year, by maturity bucket and type." tipId="tip-dmo" /> gilt stack (forecast)</h3>
          <IllustrativeBadge
            sourceSummary="DMO 2026/27 Gilt Remit (published alongside the Spring Statement) and OBR EFO Table 3.8 (Spring Forecast 2026). PSND/GDP and debt-interest are OBR forecasts for FY 2026/27, not outturns."
            sourceUrl="https://www.gov.uk/government/publications/debt-management-report-2026-27/debt-management-report-2026-27"
          />
        </div>
        <p class="hint">Planned 2026/27 issuance · £252.1bn total · GDP = £2,709bn (OBR Spring Forecast 2026)</p>
        <table class="gilt-table">
          <thead>
            <tr><th></th><th>Nominal</th><th>% of GDP</th></tr>
          </thead>
          <tbody>
            <tr><td>Total issuance</td><td>£252.1bn</td><td>9.3%</td></tr>
            <tr><td>Short conventional</td><td>£72.1bn</td><td>2.7%</td></tr>
            <tr><td>Medium conventional</td><td>£81.8bn</td><td>3.0%</td></tr>
            <tr><td>Long conventional</td><td>£74.7bn</td><td>2.8%</td></tr>
            <tr><td>Index-linked</td><td>£23.4bn</td><td>0.9%</td></tr>
          </tbody>
        </table>
        <div class="factrow" style="margin-top: 12px;"><span class="k"><IndicatorTooltip label="PSND / GDP (FY 2026/27 forecast)" description="Public-Sector Net Debt as a share of nominal GDP — the conventional headline UK debt-burden metric. Figure shown is OBR's forecast for FY 2026/27, not an outturn." tipId="tip-psnd" /></span><span class="v">93.1%</span></div>
        <div class="factrow"><span class="k">Debt interest, FY 2026/27 (forecast)</span><span class="v">£111.3bn</span></div>
      </div>
    </div>
  </div>
</section>

<style>
.section-head {
  display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 24px;
  margin-bottom: 40px;
}
.pillar-score { display: flex; align-items: baseline; gap: 6px; font-family: var(--font-mono); }
.pillar-score-num { font-size: 40px; font-weight: 500; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.pillar-score-sub { color: var(--ink-2); font-size: 14px; }
.pillar-score-delta { margin-left: 12px; font-size: 12px; }
.pillar-score-delta.up { color: var(--band-slack); }
.pillar-score-delta.dn { color: var(--band-acute); }
.pillar-score-delta.flat { color: var(--ink-2); }
.pillar-score-delta .trend-word { font-style: italic; opacity: 0.85; }

.fiscal-grid { display: grid; grid-template-columns: 1.3fr 1fr; gap: 32px; }
.card-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 2px; }
.card-head h3 { margin: 0; }

.gilt-table {
  width: 100%; border-collapse: collapse; margin-top: 8px;
  font-family: var(--font-mono); font-size: 12px;
}
.gilt-table th {
  text-align: right; font-weight: 500; font-size: 10px;
  letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-2);
  padding: 6px 10px; border-bottom: 1px solid var(--border-soft);
}
.gilt-table th:first-child { text-align: left; }
.gilt-table td {
  padding: 7px 10px; border-bottom: 1px solid var(--border-soft); color: var(--ink-1);
}
.gilt-table td:first-child { color: var(--ink-0); font-weight: 400; }
.gilt-table td:nth-child(2),
.gilt-table td:nth-child(3) { text-align: right; font-variant-numeric: tabular-nums; }
.gilt-table tbody tr:first-child td { font-weight: 500; color: var(--ink-0); }

@media (max-width: 920px) {
  .fiscal-grid { grid-template-columns: 1fr; }
  .section-head { grid-template-columns: 1fr; }
}
</style>
