---
import type { HeadlineScore } from "@tightrope/shared";
import { bandFor, BANDS, PILLARS } from "@tightrope/shared";
import TightropeWalker from "./TightropeWalker.astro";
import { eyebrowDate, signedDelta, trendArrow, trendClass } from "~/lib/format.js";

interface Props {
  headline: HeadlineScore;
}

const { headline } = Astro.props;
const band = BANDS.find((b) => b.id === headline.band) ?? bandFor(headline.value);
const bandColour = band.colourToken;
const dominantLabel = PILLARS[headline.dominantPillar]?.title ?? "The dominant pillar";
const scoreRounded = Math.round(headline.value);
const editorial = headline.editorial || `${dominantLabel} is the dominant pillar. See the sections below for the drivers.`;

const delta24 = headline.delta24h;
const delta30 = headline.delta30d;
const deltaYtd = headline.deltaYtd;
const isStale = headline.stale === true;

// When delta30d / deltaYtd baselines are set, the label "30d" / "YTD"
// is dishonest — the row we subtracted isn't actually 30d / YTD old.
// Rendering rule:
//   - If both baselines are set AND identical, show ONE "since DD MMM"
//     row (not two copies of the same number). This is the bootstrap
//     case where history is too short for either window.
//   - If only one baseline is set, label that delta "since DD MMM" and
//     keep the other as "30d" or "YTD" as appropriate.
//   - If neither baseline is set, keep the conventional "30d" / "YTD"
//     labels — they're literal truth.
function shortDateLabel(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "unknown";
  const day = d.getUTCDate();
  const mon = d.toLocaleString("en-GB", { month: "short", timeZone: "UTC" });
  return `${day} ${mon}`;
}
const d30Base = headline.delta30dBaselineDate;
const dYtdBase = headline.deltaYtdBaselineDate;
const sharedFallback = Boolean(d30Base && dYtdBase && d30Base === dYtdBase);
const delta30Label = d30Base ? `since ${shortDateLabel(d30Base)}` : "30d";
const deltaYtdLabel = dYtdBase ? `since ${shortDateLabel(dYtdBase)}` : "YTD";
const delta30Tip = d30Base
  ? `Baseline: ${shortDateLabel(d30Base)} — history does not yet stretch back a full 30 days.`
  : "Baseline: 30 days ago.";
const deltaYtdTip = dYtdBase
  ? `Baseline: ${shortDateLabel(d30Base ?? dYtdBase)} — history does not yet stretch back to 1 January.`
  : "Baseline: 1 January of the current year.";
---
<section class="hero" id="headline">
  <div class="container">
    <div class="hero-grid">
      <div>
        <span class="eyebrow">Civic data · {eyebrowDate(headline.updatedAt)}</span>
        <h1>the UK is walking a <span class="lfg-u">fiscal tightrope</span>. this is how <span class="lfg-u lfg-u--blue">unstable</span> it is, right now.</h1>
        <p class="lede">A live, transparent accountability dashboard tracking the real constraints on the UK government's growth agenda — markets, fiscal rules, the labour force, and delivery. One score. Four pillars. Every number sourced and open.</p>

        <div class="score-card" style={`--band-colour: var(${bandColour});`}>
          <div>
            <div class="score-num" data-target={scoreRounded} aria-label={`Tightrope Score: ${scoreRounded} out of 100`}>
              <span class="score-value">{scoreRounded}</span><span class="sub">/100</span>
            </div>
            <div class="delta-row" aria-label="Changes over time">
              <span title="Baseline: one UTC day before the latest reading.">1d <span class={trendClass(delta24)}>{trendArrow(delta24)} {signedDelta(Math.abs(delta24), 1)}</span></span>
              {sharedFallback ? (
                <span class="delta-since" title={`History is only ~${Math.max(0, Math.round((Date.now() - new Date(d30Base!).getTime()) / 86_400_000))} days deep; 30d and YTD would both read the same number, so only one "since ${shortDateLabel(d30Base!)}" delta is shown until the backfill catches up.`}>since {shortDateLabel(d30Base!)} <span class={trendClass(delta30)}>{trendArrow(delta30)} {signedDelta(Math.abs(delta30), 1)}</span></span>
              ) : (
                <>
                  <span title={delta30Tip}>{delta30Label} <span class={trendClass(delta30)}>{trendArrow(delta30)} {signedDelta(Math.abs(delta30), 1)}</span></span>
                  <span title={deltaYtdTip}>{deltaYtdLabel} <span class={trendClass(deltaYtd)}>{trendArrow(deltaYtd)} {signedDelta(Math.abs(deltaYtd), 1)}</span></span>
                </>
              )}
            </div>
          </div>
          <div class="score-meta">
            <span class="band-pill" style={`color: var(${bandColour}); border-color: var(${bandColour}); background: color-mix(in srgb, var(${bandColour}) 12%, transparent);`}>{band.label}</span>
            {isStale ? <span class="stale-chip" role="status" title="One or more pillars have not received fresh indicator data within the staleness window.">Stale data</span> : null}
            <span class="band-label">{band.editorialLabel}</span>
          </div>
        </div>

        <div class="editorial" role="note">
          <strong>What's driving today:</strong> {editorial}
          <span class="ts">Auto-generated from live data · <a href="/methodology" style="color: var(--accent);">see methodology →</a></span>
        </div>
      </div>

      <TightropeWalker score={scoreRounded} />
    </div>
  </div>
</section>

<style>
.hero { padding: 72px 0 56px; border-bottom: 1px solid var(--border-soft); }
.hero-grid { display: grid; grid-template-columns: 1.35fr 1fr; gap: 56px; align-items: center; }
.hero h1 {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(40px, 5vw, 64px);
  line-height: 1.02;
  letter-spacing: -0.02em;
  margin: 24px 0 22px;
}
.hero .lede { color: var(--ink-1); font-size: 17px; max-width: 560px; margin: 0 0 32px; line-height: 1.6; }

.score-card {
  background: linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 100%);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 28px 32px;
  display: grid; grid-template-columns: auto 1fr; gap: 32px; align-items: center;
  position: relative;
  overflow: hidden;
}
.score-card::before {
  content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: var(--band-colour, var(--band-acute));
}
.score-num { font-family: var(--font-mono); font-size: 88px; font-weight: 500; letter-spacing: -0.04em; line-height: 1; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.score-num .sub { font-size: 22px; color: var(--ink-2); font-weight: 400; }
.score-meta { display: flex; flex-direction: column; gap: 6px; }
.band-pill {
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
  align-self: flex-start;
  padding: 5px 11px; border-radius: 999px;
  border: 1px solid var(--accent-dim);
}
.stale-chip {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  align-self: flex-start;
  padding: 4px 9px; border-radius: 999px;
  border: 1px dashed var(--ink-2);
  color: var(--ink-2);
  margin-top: 4px;
}
.band-label { font-family: var(--font-sans); font-size: 24px; letter-spacing: -0.01em; color: var(--ink-0); font-weight: 400; font-style: italic; margin-top: 2px; }
.delta-row { display: flex; gap: 20px; margin-top: 10px; font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); }
.delta-row span.up { color: var(--band-acute); }
.delta-row span.dn { color: var(--band-slack); }
.delta-row span.flat { color: var(--ink-2); }

.editorial {
  margin-top: 24px;
  padding: 16px 20px;
  border-left: 2px solid var(--accent-dim);
  background: color-mix(in srgb, var(--accent) 4%, transparent);
  color: var(--ink-1);
  font-size: 14.5px;
  line-height: 1.6;
}
.editorial strong { color: var(--ink-0); font-weight: 500; }
.editorial .ts { font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); margin-top: 6px; display: block; letter-spacing: 0.05em; }

@media (max-width: 920px) {
  .hero-grid { grid-template-columns: 1fr; gap: 40px; }
}

@media (max-width: 600px) {
  .hero { padding: 36px 0 40px; }
  .hero h1 { font-size: clamp(30px, 8vw, 38px); margin: 18px 0 16px; }
  .hero .lede { font-size: 15px; margin-bottom: 22px; }
  .score-card { padding: 20px 18px; gap: 18px; grid-template-columns: 1fr; }
  .score-num { font-size: 64px; }
  .score-num .sub { font-size: 18px; }
  .band-label { font-size: 22px; }
  .delta-row { gap: 14px; font-size: 11px; }
  .editorial { padding: 14px 16px; font-size: 13.5px; margin-top: 18px; }
}
</style>

<script>
(() => {
  const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;
  const el = document.querySelector<HTMLElement>(".score-num");
  if (!el) return;
  const valueEl = el.querySelector<HTMLElement>(".score-value");
  if (!valueEl) return;
  const target = Number(el.dataset.target ?? valueEl.textContent ?? "0");
  if (!Number.isFinite(target)) return;
  if (reduce) { valueEl.textContent = String(target); return; }

  const dur = 900;
  const t0 = performance.now();
  valueEl.textContent = "0";
  function frame(t: number) {
    const p = Math.min(1, (t - t0) / dur);
    const eased = 1 - Math.pow(1 - p, 3);
    valueEl!.textContent = String(Math.round(target * eased));
    if (p < 1) requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
