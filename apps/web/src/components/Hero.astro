---
import type { HeadlineScore } from "@tightrope/shared";
import { bandFor, BANDS, OBR_LATEST_VINTAGE_LABEL, OBR_TARGET_YEAR_LABEL, PILLARS } from "@tightrope/shared";
import TightropeWalker from "./TightropeWalker.astro";
import { eyebrowDate, signedDelta, trendArrow, trendClass, trendDescriptor } from "~/lib/format.js";

interface Props {
  headline: HeadlineScore;
  /**
   * ISO timestamp of the freshest indicator observation across all pillars,
   * not the recompute time stamped on `headline.updatedAt`. Used in the
   * eyebrow so the page-level "as of" line reflects the underlying data,
   * not the 5-minute recompute heartbeat.
   */
  freshestAt?: string | null;
  /**
   * Last few OBR cb_headroom vintages, latest first. When present, the hero
   * renders a paired £Bn-headroom card alongside the composite, with the
   * delta between [0] and [1] displayed as "since previous EFO". The pair
   * exists so a TV viewer has BOTH the composite (down = less room to move)
   * AND the intuitive £Bn anchor (down = less fiscal freedom).
   */
  headroomVintages?: ReadonlyArray<{ value: number; observedAt: string }>;
}

const { headline, freshestAt, headroomVintages = [] } = Astro.props;
const band = BANDS.find((b) => b.id === headline.band) ?? bandFor(headline.value);
const bandColour = band.colourToken;
const dominantLabel = PILLARS[headline.dominantPillar]?.title ?? "The biggest drag";
const scoreRounded = Math.round(headline.value);
const editorial = headline.editorial || `${dominantLabel} is the biggest drag. See the sections below for the drivers.`;

const delta24 = headline.delta24h;
const delta30 = headline.delta30d;
const deltaYtd = headline.deltaYtd;
const isStale = headline.stale === true;

// When delta30d / deltaYtd baselines are set, the label "30d" / "YTD"
// is dishonest — the row we subtracted isn't actually 30d / YTD old.
// Rendering rule:
//   - If both baselines are set AND identical, show ONE "since DD MMM"
//     row (not two copies of the same number). This is the bootstrap
//     case where history is too short for either window.
//   - If only one baseline is set, label that delta "since DD MMM" and
//     keep the other as "30d" or "YTD" as appropriate.
//   - If neither baseline is set, keep the conventional "30d" / "YTD"
//     labels — they're literal truth.
function shortDateLabel(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "unknown";
  const day = d.getUTCDate();
  const mon = d.toLocaleString("en-GB", { month: "short", timeZone: "UTC" });
  return `${day} ${mon}`;
}
const d30Base = headline.delta30dBaselineDate;
const dYtdBase = headline.deltaYtdBaselineDate;
const sharedFallback = Boolean(d30Base && dYtdBase && d30Base === dYtdBase);
const delta30Label = d30Base ? `since ${shortDateLabel(d30Base)}` : "30d";
const deltaYtdLabel = dYtdBase ? `since ${shortDateLabel(dYtdBase)}` : "YTD";
const delta30Tip = d30Base
  ? `Baseline: ${shortDateLabel(d30Base)} — history does not yet stretch back a full 30 days.`
  : "Baseline: 30 days ago.";
const deltaYtdTip = dYtdBase
  ? `Baseline: ${shortDateLabel(d30Base ?? dYtdBase)} — history does not yet stretch back to 1 January.`
  : "Baseline: 1 January of the current year.";

// Headroom card data. We require at least one vintage; the prior-vintage
// delta is only computed when a second vintage is present. The visual
// convention mirrors the composite card: a coloured side-bar, a big
// number, a direction caption, and a delta row.
const headroomCurrent = headroomVintages[0];
const headroomPrior = headroomVintages[1];
const headroomDelta = (headroomCurrent && headroomPrior)
  ? Math.round((headroomCurrent.value - headroomPrior.value) * 10) / 10
  : null;
// Headroom delta colour: a falling £Bn buffer is less fiscal freedom, so
// negative deltas paint red (`dn`) and positive paint green (`up`). The
// classes resolve to band-acute / band-slack via the .delta-row CSS rules
// below — same vocabulary as the composite card's delta row, even though
// the underlying axis here is £Bn (down = bad) rather than the public score
// (up = good). For the headroom card both conventions point the same way:
// negative → red, positive → green.
const headroomDeltaClass = headroomDelta === null
  ? "flat"
  : headroomDelta < 0 ? "dn" : headroomDelta > 0 ? "up" : "flat";
const headroomDeltaArrow = headroomDelta === null
  ? "→"
  : headroomDelta < 0 ? "↓" : headroomDelta > 0 ? "↑" : "→";
function headroomDateLabel(iso: string): string {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "unknown";
  const mon = d.toLocaleString("en-GB", { month: "short", year: "numeric", timeZone: "UTC" });
  return mon;
}
---
<section class="hero" id="headline">
  <div class="container">
    <div class="hero-grid">
      <div>
        <span
          class="eyebrow"
          title={`Latest indicator observation: ${eyebrowDate(freshestAt ?? headline.updatedAt)}. Recompute heartbeat: ${eyebrowDate(headline.updatedAt)}.`}
        >Civic data · {eyebrowDate(freshestAt ?? headline.updatedAt)}</span>
        <h1>the UK is on a <span class="lfg-u">fiscal tightrope</span>. the steadier the rope, the more room to <span class="lfg-u lfg-u--blue">move forward</span>.</h1>
        <p class="lede">The Tightrope Score runs from 0 to 100: <strong>higher means more room to move</strong>, lower means the rope is closer to giving way. Markets, fiscal headroom, the labour force, and growth delivery each pull on the rope; the score is the geometric mean of those four pillars. Every number sourced and open.</p>

        <div class="dual-cards">
          <div class="score-card composite-card" style={`--band-colour: var(${bandColour});`}>
            <div class="card-header">
              <span class="card-label">Tightrope Score</span>
              <span class="card-direction" title="The composite. Higher numbers mean more room to move; lower numbers mean the rope is closer to giving way.">↑ HIGHER = BETTER</span>
            </div>
            <div>
              <div class="score-num" data-target={scoreRounded} aria-label={`Tightrope Score: ${scoreRounded} out of 100`}>
                <span class="score-value">{scoreRounded}</span><span class="sub">/100</span>
              </div>
              <div class="delta-row" aria-label="Composite changes over time">
                <span title="Baseline: one UTC day before the latest reading.">1d <span class={trendClass(delta24)}>{trendArrow(delta24)} {signedDelta(delta24, 1)}{trendDescriptor(delta24) ? <span class="trend-word"> {trendDescriptor(delta24)}</span> : null}</span></span>
                {sharedFallback ? (
                  <span class="delta-since" title={`History is only ~${Math.max(0, Math.round((Date.now() - new Date(d30Base!).getTime()) / 86_400_000))} days deep; 30d and YTD would both read the same number, so only one "since ${shortDateLabel(d30Base!)}" delta is shown until the backfill catches up.`}>since {shortDateLabel(d30Base!)} <span class={trendClass(delta30)}>{trendArrow(delta30)} {signedDelta(delta30, 1)}{trendDescriptor(delta30) ? <span class="trend-word"> {trendDescriptor(delta30)}</span> : null}</span></span>
                ) : (
                  <>
                    <span title={delta30Tip}>{delta30Label} <span class={trendClass(delta30)}>{trendArrow(delta30)} {signedDelta(delta30, 1)}{trendDescriptor(delta30) ? <span class="trend-word"> {trendDescriptor(delta30)}</span> : null}</span></span>
                    <span title={deltaYtdTip}>{deltaYtdLabel} <span class={trendClass(deltaYtd)}>{trendArrow(deltaYtd)} {signedDelta(deltaYtd, 1)}{trendDescriptor(deltaYtd) ? <span class="trend-word"> {trendDescriptor(deltaYtd)}</span> : null}</span></span>
                  </>
                )}
              </div>
            </div>
            <div class="score-meta">
              <span class="band-pill" style={`color: var(${bandColour}); border-color: var(${bandColour}); background: color-mix(in srgb, var(${bandColour}) 12%, transparent);`}>{band.label}</span>
              {isStale ? <span class="stale-chip" role="status" title="One or more pillars have not received fresh indicator data within the staleness window.">Stale data</span> : null}
              <span class="band-label">{band.editorialLabel}</span>
            </div>
          </div>

          {headroomCurrent ? (
            <div class="score-card headroom-card">
              <div class="card-header">
                <span class="card-label">Fiscal headroom · {OBR_TARGET_YEAR_LABEL}</span>
                <span class="card-direction" title="The OBR's forecast £-billion buffer against the stability rule for the target year. Lower numbers = less room to spend, tax less, or absorb a shock.">↓ LESS FREEDOM</span>
              </div>
              <div>
                <div class="score-num" aria-label={`Forecast headroom: £${headroomCurrent.value.toFixed(1)} billion`}>
                  <span class="score-pound">£</span><span class="score-value">{headroomCurrent.value.toFixed(1)}</span><span class="sub">bn</span>
                </div>
                <div class="delta-row" aria-label="Headroom changes between OBR forecasts">
                  {headroomDelta !== null && headroomPrior ? (
                    <span title={`Previous OBR vintage: ${headroomDateLabel(headroomPrior.observedAt)} (£${headroomPrior.value.toFixed(1)}bn).`}>
                      since previous EFO <span class={headroomDeltaClass}>{headroomDeltaArrow} £{Math.abs(headroomDelta).toFixed(1)}bn</span>
                    </span>
                  ) : (
                    <span title="Only one OBR vintage in our store yet — a delta will appear at the next EFO.">awaiting next OBR vintage</span>
                  )}
                </div>
              </div>
              <div class="score-meta">
                <span class="band-pill headroom-pill">OBR forecast · {OBR_LATEST_VINTAGE_LABEL}</span>
                <span class="band-label headroom-sub">Surplus against the current-budget stability rule.</span>
              </div>
            </div>
          ) : null}
        </div>

        <div class="editorial" role="note">
          <strong>What's driving today:</strong> {editorial}
          <span class="ts">Auto-generated from live data · <a href="/methodology" style="color: var(--accent);">see methodology →</a></span>
        </div>
      </div>

      <TightropeWalker score={100 - scoreRounded} />
    </div>
  </div>
</section>

<style>
.hero { padding: 72px 0 56px; border-bottom: 1px solid var(--border-soft); }
.hero-grid { display: grid; grid-template-columns: 1.35fr 1fr; gap: 56px; align-items: center; }
.hero h1 {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(40px, 5vw, 64px);
  line-height: 1.02;
  letter-spacing: -0.02em;
  margin: 24px 0 22px;
}
.hero .lede { color: var(--ink-1); font-size: 17px; max-width: 560px; margin: 0 0 32px; line-height: 1.6; }

.dual-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  align-items: stretch;
}
.score-card {
  background: linear-gradient(180deg, var(--bg-1) 0%, var(--bg-0) 100%);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 22px 26px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  position: relative;
  overflow: hidden;
}
.score-card::before {
  content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: var(--band-colour, var(--accent));
}
.headroom-card::before { background: var(--accent); }
.card-header {
  display: flex; flex-direction: column; gap: 4px;
}
.card-label {
  font-family: var(--font-mono);
  font-size: 10.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--ink-2);
}
.card-direction {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-1);
  font-weight: 500;
}
/* Caption colour stays neutral so the legend never mis-paints (e.g. a green
   "HIGHER = BETTER" alongside a red critical score, or vice-versa). The
   band colour is already carried by the side-bar, the band pill, and the
   editorial label below — the legend is a permanent direction-of-travel
   gloss, not a value-of-the-day signal. */
.composite-card .card-direction { color: var(--ink-2); }
.headroom-card .card-direction { color: var(--accent); }
.score-num {
  font-family: var(--font-mono);
  font-size: 64px;
  font-weight: 500;
  letter-spacing: -0.04em;
  line-height: 1;
  color: var(--ink-0);
  font-variant-numeric: tabular-nums;
}
.score-num .sub { font-size: 18px; color: var(--ink-2); font-weight: 400; margin-left: 2px; }
.score-num .score-pound { font-size: 38px; color: var(--ink-2); font-weight: 400; margin-right: 4px; vertical-align: 8px; }
.score-meta { display: flex; flex-direction: column; gap: 4px; margin-top: auto; }
.band-pill {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  align-self: flex-start;
  padding: 4px 10px; border-radius: 999px;
  border: 1px solid var(--accent-dim);
}
.headroom-pill { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 50%, transparent); background: color-mix(in srgb, var(--accent) 10%, transparent); }
.stale-chip {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  align-self: flex-start;
  padding: 4px 9px; border-radius: 999px;
  border: 1px dashed var(--ink-2);
  color: var(--ink-2);
  margin-top: 4px;
}
.band-label { font-family: var(--font-sans); font-size: 16px; letter-spacing: -0.01em; color: var(--ink-0); font-weight: 400; font-style: italic; margin-top: 2px; }
.headroom-sub { font-style: normal; font-size: 13px; color: var(--ink-1); }
.delta-row { display: flex; gap: 16px; margin-top: 8px; font-family: var(--font-mono); font-size: 11.5px; color: var(--ink-2); flex-wrap: wrap; }
.delta-row span.up { color: var(--band-slack); }
.delta-row span.dn { color: var(--band-acute); }
.delta-row span.flat { color: var(--ink-2); }
.delta-row .trend-word { font-style: italic; opacity: 0.85; }

.editorial {
  margin-top: 24px;
  padding: 16px 20px;
  border-left: 2px solid var(--accent-dim);
  background: color-mix(in srgb, var(--accent) 4%, transparent);
  color: var(--ink-1);
  font-size: 14.5px;
  line-height: 1.6;
}
.editorial strong { color: var(--ink-0); font-weight: 500; }
.editorial .ts { font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); margin-top: 6px; display: block; letter-spacing: 0.05em; }

@media (max-width: 920px) {
  .hero-grid { grid-template-columns: 1fr; gap: 40px; }
}

@media (max-width: 720px) {
  .dual-cards { grid-template-columns: 1fr; }
}

@media (max-width: 600px) {
  .hero { padding: 36px 0 40px; }
  .hero h1 { font-size: clamp(30px, 8vw, 38px); margin: 18px 0 16px; }
  .hero .lede { font-size: 15px; margin-bottom: 22px; }
  .score-card { padding: 18px 18px; gap: 12px; }
  .score-num { font-size: 56px; }
  .score-num .sub { font-size: 16px; }
  .score-num .score-pound { font-size: 32px; }
  .band-label { font-size: 15px; }
  .delta-row { gap: 12px; font-size: 11px; }
  .editorial { padding: 14px 16px; font-size: 13.5px; margin-top: 18px; }
}
</style>

<script is:inline nonce={Astro.locals.cspNonce}>
(() => {
  const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;
  const el = document.querySelector(".composite-card .score-num");
  if (!el) return;
  const valueEl = el.querySelector(".score-value");
  if (!valueEl) return;
  const target = Number(el.dataset.target ?? valueEl.textContent ?? "0");
  if (!Number.isFinite(target)) return;
  if (reduce) { valueEl.textContent = String(target); return; }

  const dur = 900;
  const t0 = performance.now();
  valueEl.textContent = "0";
  function frame(t) {
    const p = Math.min(1, (t - t0) / dur);
    const eased = 1 - Math.pow(1 - p, 3);
    valueEl.textContent = String(Math.round(target * eased));
    if (p < 1) requestAnimationFrame(frame);
  }
  requestAnimationFrame(frame);
})();
</script>
