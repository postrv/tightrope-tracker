---
import type { PillarScore } from "@tightrope/shared";
import { signedDelta } from "~/lib/format.js";
import { mortgageDelta, formatExtra } from "~/lib/mortgage.js";
import IllustrativeBadge from "./IllustrativeBadge.astro";

interface Props {
  pillar: PillarScore;
}

const { pillar } = Astro.props;

// Editorial baseline (rate at last Budget) and current rate.
const baselineRate = 5.18;
const currentRate = 5.84;
const m = mortgageDelta(baselineRate, currentRate, 250_000, 25);

// Dual-axis inactivity chart data: quarterly 2019-2026.
// [label, rate %, health-related m]
const inactivity = [
  ["2019", 20.4, 2.00],
  ["2020", 20.8, 2.10],
  ["2021", 21.2, 2.35],
  ["2022", 21.6, 2.55],
  ["2023", 21.7, 2.70],
  ["2024", 21.2, 2.78],
  ["2025", 20.9, 2.80],
  ["2026", 20.7, 2.81],
] as const;

// VU ratio — illustrative monthly series (roughly 1.1 at peak, falling)
const vuRatio = [1.08, 1.05, 1.00, 0.94, 0.90, 0.85, 0.82, 0.80, 0.78, 0.76, 0.74, 0.72];
// Real regular pay YoY — illustrative (negative 2022, rebound)
const realPay = [-2.3, -1.9, -1.2, -0.4, 0.3, 1.0, 1.6, 2.1, 2.0, 1.7, 1.5, 1.3];

function svgLinePath(values: readonly number[], w: number, h: number, pad = 8): string {
  const min = Math.min(...values);
  const max = Math.max(...values);
  const range = max === min ? 1 : max - min;
  return values.map((v, i) => {
    const x = pad + (i / (values.length - 1)) * (w - pad * 2);
    const y = h - pad - ((v - min) / range) * (h - pad * 2);
    return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
  }).join(" ");
}
---
<section class="section" id="labour" aria-labelledby="labour-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Pillar 3 · 20%</span>
        <h2 class="sec-title" id="labour-title" style="margin-top: 14px;">Labour & living-standards strain</h2>
        <p class="section-sub">Health-related inactivity, labour-market tightness, real wages and — the line households feel — mortgage rates.</p>
      </div>
      <div class="pillar-score" aria-label={`Labour pillar score ${Math.round(pillar.value)}`}>
        <span class="pillar-score-num">{Math.round(pillar.value)}</span>
        <span class="pillar-score-sub">/100</span>
        {(() => {
          const t30 = pillar.trend30d ?? "flat";
          const d30 = typeof pillar.delta30d === "number" ? pillar.delta30d : 0;
          const cls = t30 === "up" ? "up" : t30 === "down" ? "dn" : "flat";
          return (
            <span class={`pillar-score-delta ${cls}`} title="Change across the 30-day sparkline window (first to last point).">
              {t30 === "flat" ? "flat" : `${t30 === "up" ? "▲" : "▼"} ${signedDelta(Math.abs(d30), 1)}`} / 30d
            </span>
          );
        })()}
      </div>
    </div>

    <div class="labour-grid">
      <div class="chart-card wide">
        <div class="card-head">
          <h3>Inactivity rate vs. health-related count</h3>
          <IllustrativeBadge
            sourceSummary="Annual averages from ONS Labour Force Survey: inactivity rate (series LF24) and health-related economically inactive (series LF2R). One point per year."
            sourceUrl="https://www.ons.gov.uk/employmentandlabourmarket/peoplenotinwork/economicinactivity"
          />
        </div>
        <p class="hint">Annual averages, 16-64. Left axis: rate (%). Right axis: health-related inactive (millions).</p>
        <svg class="chart" viewBox="0 0 600 240" preserveAspectRatio="none" role="img" aria-label="Inactivity rate and health-related inactivity 2019 to 2026">
          <g stroke="var(--border-soft)" stroke-width="1">
            <line x1="40" y1="40" x2="560" y2="40"/>
            <line x1="40" y1="100" x2="560" y2="100"/>
            <line x1="40" y1="160" x2="560" y2="160"/>
            <line x1="40" y1="220" x2="560" y2="220"/>
          </g>
          <g font-family="IBM Plex Mono" font-size="10" fill="var(--ink-2)">
            <text x="32" y="44" text-anchor="end">22.0%</text>
            <text x="32" y="104" text-anchor="end">21.0%</text>
            <text x="32" y="164" text-anchor="end">20.5%</text>
            <text x="32" y="224" text-anchor="end">20.0%</text>
          </g>
          <g font-family="IBM Plex Mono" font-size="10" fill="var(--band-acute)">
            <text x="568" y="44">3.0m</text>
            <text x="568" y="104">2.5m</text>
            <text x="568" y="164">2.0m</text>
            <text x="568" y="224">1.5m</text>
          </g>
          <g font-family="IBM Plex Mono" font-size="9.5" fill="var(--ink-2)">
            {inactivity.map((row, i) => {
              const x = 60 + (i / (inactivity.length - 1)) * 480;
              return <text x={x} y={234} text-anchor="middle">{row[0] as string}</text>;
            })}
          </g>

          {/* Inactivity rate line (left axis: 20% -> 220, 22% -> 40) */}
          <path
            d={inactivity.map((row, i) => {
              const x = 60 + (i / (inactivity.length - 1)) * 480;
              const r = row[1] as number;
              const y = 220 - ((r - 20) / 2) * 180;
              return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
            }).join(" ")}
            stroke="var(--ink-0)" stroke-width="1.6" fill="none"
          />
          {/* Health-related count line (right axis: 1.5m -> 220, 3m -> 40) */}
          <path
            d={inactivity.map((row, i) => {
              const x = 60 + (i / (inactivity.length - 1)) * 480;
              const v = row[2] as number;
              const y = 220 - ((v - 1.5) / 1.5) * 180;
              return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
            }).join(" ")}
            stroke="var(--band-acute)" stroke-width="1.6" fill="none" stroke-dasharray="4 3"
          />

          {inactivity.map((row, i) => {
            const x = 60 + (i / (inactivity.length - 1)) * 480;
            const r = row[1] as number;
            const y = 220 - ((r - 20) / 2) * 180;
            return <circle cx={x} cy={y} r="2.5" fill="var(--ink-0)" />;
          })}
        </svg>
        <div class="legend">
          <span class="lg"><span class="sw solid" style="background: var(--ink-0);"></span> Inactivity rate (left)</span>
          <span class="lg"><span class="sw dashed" style="background: var(--band-acute);"></span> Health-related inactive (right)</span>
        </div>
      </div>

      <div class="mortgage-card">
        <div class="card-head">
          <h3>Mortgage translator</h3>
          <IllustrativeBadge
            sourceSummary="Arithmetic worked from the live 2-year fixed rate (indicator `mortgage_2y_fix`, Moneyfacts). The £250k / 25-year worked example is illustrative — change the two rates in apps/web/src/lib/mortgage.js to reproduce."
            sourceUrl="https://www.moneyfactscompare.co.uk/mortgages/"
          />
        </div>
        <p class="hint">What the 2-year fixed-rate move means on a £250,000, 25-year repayment mortgage.</p>
        <div class="mortgage-big">{formatExtra(m.extraPerMonth)}<span class="mortgage-sub"> / month</span></div>
        <p class="mortgage-caption">Extra vs. the rate at the last Budget ({m.baselineRate.toFixed(2)}% → {m.currentRate.toFixed(2)}%). Payment: £{m.currentPayment.toLocaleString("en-GB")} vs. £{m.baselinePayment.toLocaleString("en-GB")}.</p>
        <p class="mortgage-note">This is the line you will see quoted in the press. The rate series is Moneyfacts' reported average 2-year fix at 75% LTV.</p>
      </div>
    </div>

    <div class="labour-secondary">
      <div class="chart-card">
        <div class="card-head">
          <h3>Vacancies per unemployed person</h3>
          <IllustrativeBadge
            sourceSummary="Derived ratio of ONS monthly vacancies (V) over ONS monthly unemployed (U). Live indicator `vacancies_per_unemployed` feeds from the same adapter — this chart shows the illustrative 12-month arc."
            sourceUrl="https://www.ons.gov.uk/employmentandlabourmarket/peoplenotinwork/unemployment"
          />
        </div>
        <p class="hint">Rolling quarterly ratio — falling = more slack appearing in the labour market.</p>
        <svg class="chart" viewBox="0 0 400 160" preserveAspectRatio="none" role="img" aria-label="Vacancies per unemployed person">
          <g stroke="var(--border-soft)" stroke-width="1">
            <line x1="30" y1="20" x2="390" y2="20"/>
            <line x1="30" y1="80" x2="390" y2="80"/>
            <line x1="30" y1="140" x2="390" y2="140"/>
          </g>
          <path d={svgLinePath(vuRatio, 400, 160, 30)} stroke="var(--band-strain)" stroke-width="1.6" fill="none"/>
        </svg>
      </div>
      <div class="chart-card">
        <div class="card-head">
          <h3>Real regular pay growth (YoY)</h3>
          <IllustrativeBadge
            sourceSummary="ONS Average Weekly Earnings regular pay (series KAC3) deflated by CPIH (L55O). Live indicator `real_regular_pay` feeds from the same ONS series."
            sourceUrl="https://www.ons.gov.uk/employmentandlabourmarket/peopleinwork/earningsandworkinghours"
          />
        </div>
        <p class="hint">CPIH-adjusted. Positive values = real wages growing.</p>
        <svg class="chart" viewBox="0 0 400 160" preserveAspectRatio="none" role="img" aria-label="Real regular pay year on year">
          <g stroke="var(--border-soft)" stroke-width="1">
            <line x1="30" y1="20" x2="390" y2="20"/>
            <line x1="30" y1="80" x2="390" y2="80"/>
            <line x1="30" y1="140" x2="390" y2="140"/>
          </g>
          <path d={svgLinePath(realPay, 400, 160, 30)} stroke="var(--band-slack)" stroke-width="1.6" fill="none"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
.section-head {
  display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 24px;
  margin-bottom: 40px;
}
.pillar-score { display: flex; align-items: baseline; gap: 6px; font-family: var(--font-mono); }
.pillar-score-num { font-size: 40px; font-weight: 500; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.pillar-score-sub { color: var(--ink-2); font-size: 14px; }
.pillar-score-delta { margin-left: 12px; font-size: 12px; }
.pillar-score-delta.up { color: var(--band-acute); }
.pillar-score-delta.dn { color: var(--band-slack); }
.pillar-score-delta.flat { color: var(--ink-2); }

.labour-grid { display: grid; grid-template-columns: 1.45fr 1fr; gap: 32px; margin-bottom: 32px; }
.labour-secondary { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
.card-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 2px; }
.card-head h3 { margin: 0; }

.mortgage-card {
  background: linear-gradient(160deg, color-mix(in srgb, var(--accent) 10%, transparent), var(--bg-1));
  border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  border-radius: 12px;
  padding: 24px;
}
.mortgage-card h3 { font-family: var(--font-serif); font-weight: 400; font-size: 20px; margin: 0 0 4px; }
.mortgage-card .hint { color: var(--ink-2); font-size: 12px; margin: 0 0 16px; }
.mortgage-big { font-family: var(--font-serif); font-size: 56px; font-weight: 700; color: var(--accent); letter-spacing: -0.025em; line-height: 1; font-variant-numeric: tabular-nums; }
.mortgage-sub { font-family: var(--font-mono); font-size: 16px; color: var(--ink-2); font-weight: 400; }
.mortgage-caption { font-family: var(--font-mono); font-size: 12px; color: var(--ink-1); margin: 14px 0 10px; letter-spacing: 0.01em; }
.mortgage-note { font-size: 12.5px; color: var(--ink-1); line-height: 1.5; margin: 0; }

.legend { display: flex; gap: 20px; margin-top: 12px; font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); }
.lg { display: inline-flex; align-items: center; gap: 8px; }
.sw { display: inline-block; width: 20px; height: 2px; }
.sw.dashed { background: repeating-linear-gradient(90deg, currentColor 0 4px, transparent 4px 8px); }

@media (max-width: 920px) {
  .labour-grid, .labour-secondary { grid-template-columns: 1fr; }
  .section-head { grid-template-columns: 1fr; }
}
</style>
