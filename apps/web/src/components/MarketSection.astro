---
import type { PillarScore, TodayMovement } from "@tightrope/shared";
import { describeSparklineCoverage } from "@tightrope/shared";
import LineChart from "./charts/LineChart.astro";
import ProvenanceBadge from "./ProvenanceBadge.astro";
import IndicatorTooltip from "./IndicatorTooltip.astro";
import { signedDelta, trendDescriptor } from "~/lib/format.js";

interface Props {
  pillar: PillarScore;
  movements: TodayMovement[];
}

const { pillar, movements } = Astro.props;

function findMovement(id: string): TodayMovement | undefined {
  return movements.find((m) => m.indicatorId === id);
}

const gilt10 = findMovement("gilt_10y");
const gilt30 = findMovement("gilt_30y");
const ftse = findMovement("ftse_250");
const gbp = findMovement("gbp_usd");
const brent = findMovement("brent_gbp");
const be5 = findMovement("breakeven_5y");
const sparkline = (pillar.sparkline30d ?? []).filter((n) => Number.isFinite(n));
const hasSparkline = sparkline.length >= 2;
const coverage = describeSparklineCoverage(sparkline);
---
<section class="section" id="market" aria-labelledby="market-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Pillar 1 · 40%</span>
        <h2 class="sec-title" id="market-title" style="margin-top: 14px;">Market pressure</h2>
        <p class="section-sub">The daily market read on UK constraint: long gilts, sterling, the rate path, mid-cap equities, and the energy input.</p>
      </div>
      <div class="pillar-score" aria-label={`Market pillar score ${Math.round(pillar.value)}`}>
        <span class="pillar-score-num">{Math.round(pillar.value)}</span>
        <span class="pillar-score-sub">/100</span>
        {(() => {
          const t30 = pillar.trend30d ?? "flat";
          const d30 = typeof pillar.delta30d === "number" ? pillar.delta30d : 0;
          const cls = t30 === "up" ? "up" : t30 === "down" ? "dn" : "flat";
          return (
            <span class={`pillar-score-delta ${cls}`} title="Change across the 30-day sparkline window (first to last point).">
              {t30 === "flat" ? "flat" : (
                <>
                  {t30 === "up" ? "▲" : "▼"} {signedDelta(Math.abs(d30), 1)}
                  {trendDescriptor(d30) ? <span class="trend-word"> {trendDescriptor(d30)}</span> : null}
                </>
              )} / 30d
            </span>
          );
        })()}
      </div>
    </div>

    <div class="market-grid">
      <div class="chart-card">
        <h3>Gilt curve anchors</h3>
        <p class="hint">10y and 20y zero-coupon yields, breakeven inflation, and risk assets.</p>
        <div class="quad">
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="10y gilt" indicatorId="gilt_10y" /></span><ProvenanceBadge indicatorId="gilt_10y" compact /></div>
            <span class="mini-val">{gilt10?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${gilt10?.worsening ? "up" : "dn"}`}>{gilt10?.changeDisplay ?? ""}</span>
          </div>
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="20y gilt" indicatorId="gilt_30y" /></span><ProvenanceBadge indicatorId="gilt_30y" compact /></div>
            <span class="mini-val">{gilt30?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${gilt30?.worsening ? "up" : "dn"}`}>{gilt30?.changeDisplay ?? ""}</span>
          </div>
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="5y BE" indicatorId="breakeven_5y" /></span><ProvenanceBadge indicatorId="breakeven_5y" compact /></div>
            <span class="mini-val">{be5?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${be5?.worsening ? "up" : "dn"}`}>{be5?.changeDisplay ?? ""}</span>
          </div>
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="GBP / USD" indicatorId="gbp_usd" /></span><ProvenanceBadge indicatorId="gbp_usd" compact /></div>
            <span class="mini-val">{gbp?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${gbp?.worsening ? "up" : "dn"}`}>{gbp?.changeDisplay ?? ""}</span>
          </div>
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="FTSE 250" indicatorId="ftse_250" /></span><ProvenanceBadge indicatorId="ftse_250" compact /></div>
            <span class="mini-val">{ftse?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${ftse?.worsening ? "up" : "dn"}`}>{ftse?.changeDisplay ?? ""}</span>
          </div>
          <div class="mini">
            <div class="mini-head"><span class="mini-label"><IndicatorTooltip label="Brent GBP" indicatorId="brent_gbp" /></span><ProvenanceBadge indicatorId="brent_gbp" compact /></div>
            <span class="mini-val">{brent?.displayValue ?? "—"}</span>
            <span class={`mini-chg ${brent?.worsening ? "up" : "dn"}`}>{brent?.changeDisplay ?? ""}</span>
          </div>
        </div>
      </div>

      <div class="chart-card">
        <h3>Market pressure trajectory</h3>
        <p class="hint">30-day pillar score. Higher = more constraint from markets.</p>
        {hasSparkline ? (
          <>
            <LineChart
              series={sparkline}
              width={540}
              height={220}
              stroke="var(--band-acute)"
              fillGradientId="marketFill"
              minLabel={`${Math.floor(Math.min(...sparkline))}`}
              maxLabel={`${Math.ceil(Math.max(...sparkline))}`}
              ariaLabel="Market pressure pillar score, last 30 days"
            />
            <p class={`coverage-note ${coverage.isComplete ? "complete" : "partial"}`}>
              Scored {coverage.plotted} of {coverage.window} days.
              {coverage.isComplete ? "" : ` ${coverage.missing} day${coverage.missing === 1 ? "" : "s"} failed quorum and are not plotted — see `}
              {coverage.isComplete ? "" : <a href="/methodology#historical-coverage">methodology</a>}
              {coverage.isComplete ? "" : "."}
            </p>
          </>
        ) : (
          <p class="chart-empty">Trajectory will populate after the first 24h of recompute history.</p>
        )}
      </div>
    </div>

    <div class="why">
      <h4>Why this matters</h4>
      <p>Long gilt yields are the price the government pays to borrow. When they rise, debt service bills rise with them, the Chancellor's fiscal headroom shrinks, and sterling often weakens — compounding inflation via imports. The 20-year zero-coupon yield is the clearest long-duration read on the BoE curve, and it is the one that moves first when policy credibility is in question.</p>
    </div>
  </div>
</section>

<style>
.section-head {
  display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 24px;
  margin-bottom: 40px;
}
.pillar-score { display: flex; align-items: baseline; gap: 6px; font-family: var(--font-mono); }
.pillar-score-num { font-size: 40px; font-weight: 500; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.pillar-score-sub { color: var(--ink-2); font-size: 14px; }
.pillar-score-delta { margin-left: 12px; font-size: 12px; }
.pillar-score-delta.up { color: var(--band-acute); }
.pillar-score-delta.dn { color: var(--band-slack); }
.pillar-score-delta.flat { color: var(--ink-2); }
.pillar-score-delta .trend-word { font-style: italic; opacity: 0.85; }

.market-grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: 32px; }
.chart-empty { font-family: var(--font-mono); font-size: 12px; color: var(--ink-2); padding: 80px 0; text-align: center; }
.coverage-note { font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); margin: 8px 0 0; letter-spacing: 0.04em; }
.coverage-note.partial { color: var(--ink-1); }
.coverage-note a { color: var(--accent); text-decoration: underline dotted; }

.quad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border-soft); border: 1px solid var(--border-soft); border-radius: 8px; overflow: hidden; margin-top: 8px; }
.mini { background: var(--bg-0); padding: 14px 16px; display: flex; flex-direction: column; gap: 4px; }
.mini-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
.mini-label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2); }
.mini-val { font-family: var(--font-mono); font-size: 20px; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.mini-chg { font-family: var(--font-mono); font-size: 11px; color: var(--ink-2); }
.mini-chg.up { color: var(--band-acute); }
.mini-chg.dn { color: var(--band-slack); }

.why {
  margin-top: 32px;
  border-left: 2px solid var(--accent-dim);
  padding: 16px 20px;
  background: color-mix(in srgb, var(--accent) 4%, transparent);
}
.why h4 { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-2); margin: 0 0 8px; font-weight: 500; }
.why p { color: var(--ink-1); font-size: 14px; margin: 0; line-height: 1.6; max-width: 760px; }

@media (max-width: 920px) {
  .market-grid { grid-template-columns: 1fr; gap: 20px; }
  .quad { grid-template-columns: repeat(2, 1fr); }
  .section-head { grid-template-columns: 1fr; }
}
</style>
