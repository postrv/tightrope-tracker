---
import type { ScoreSnapshot, TodayMovement, IndicatorContribution, PillarId } from "@tightrope/shared";
import type { DeliveryCommitment } from "@tightrope/shared/delivery";
import { BANDS, OBR_LATEST_VINTAGE_LABEL, OBR_TARGET_YEAR_LABEL } from "@tightrope/shared";
import { shortDate } from "~/lib/format.js";
import { mortgageDelta, formatExtra, MORTGAGE_BUDGET_BASELINE_PCT, MORTGAGE_BUDGET_BASELINE_LABEL } from "~/lib/mortgage.js";

interface Props {
  snapshot: ScoreSnapshot;
  movements: TodayMovement[];
  delivery: DeliveryCommitment[];
}

const { snapshot, movements, delivery } = Astro.props;

const band = BANDS.find((b) => b.id === snapshot.headline.band) ?? BANDS[0];
const scoreRounded = Math.round(snapshot.headline.value);
const today = shortDate(snapshot.headline.updatedAt);

function scoreCardVariant(id: string): string {
  if (id === "critical" || id === "acute") return "critical";
  if (id === "strained") return "accent";
  return "";
}

function findContrib(snap: ScoreSnapshot, pillar: PillarId, indicatorId: string): IndicatorContribution | undefined {
  return snap.pillars[pillar]?.contributions.find((c) => c.indicatorId === indicatorId);
}

// Live readings (or undefined if the snapshot is missing them — we hide the
// card rather than render a stale literal).
const cbHeadroom = findContrib(snapshot, "fiscal", "cb_headroom");
const inactivity = findContrib(snapshot, "labour", "inactivity_rate");
const mortgage = findContrib(snapshot, "labour", "mortgage_2y_fix");
const housingContrib = findContrib(snapshot, "delivery", "housing_trajectory");
const gilt30 = movements.find((m) => m.indicatorId === "gilt_30y");
const housingDelivery = delivery.find((d) => d.id === "housing_305k");

const mortRates = mortgage
  ? mortgageDelta(MORTGAGE_BUDGET_BASELINE_PCT, mortgage.rawValue)
  : null;

interface Card {
  id: string;
  variant: string;
  brand: string;
  stat: string;
  label: string;
  foot: [string, string];
  ogPath: string;
}

const allCards: (Card | null)[] = [
  {
    id: "headline-score",
    variant: scoreCardVariant(band.id),
    brand: "Tightrope Tracker · Headline",
    stat: `${scoreRounded} / 100`,
    label: `Tightrope Score — “${band.label}.” ${band.editorialLabel}.`,
    foot: ["tightropetracker.uk", today],
    ogPath: "/og/headline-score.png",
  },
  cbHeadroom ? {
    id: "fiscal-headroom",
    variant: "accent",
    brand: `Tightrope Tracker · Fiscal · ${OBR_TARGET_YEAR_LABEL} forecast`,
    stat: `£${cbHeadroom.rawValue.toFixed(1)}bn`,
    label: `OBR forecast headroom against the stability rule at the ${OBR_TARGET_YEAR_LABEL} target year.`,
    foot: [`Source · OBR ${OBR_LATEST_VINTAGE_LABEL}`, shortDate(cbHeadroom.observedAt)],
    ogPath: "/og/fiscal-headroom.png",
  } : null,
  inactivity ? {
    id: "inactivity",
    variant: "",
    brand: "Tightrope Tracker · Labour",
    stat: `${inactivity.rawValue.toFixed(1)}%`,
    label: "Economic-inactivity rate, 16–64 (latest ONS Labour Market Statistics print).",
    foot: ["Source · ONS LMS", shortDate(inactivity.observedAt)],
    ogPath: "/og/inactivity-9m.png",
  } : null,
  gilt30 ? {
    id: "gilt-30y",
    variant: "",
    brand: "Tightrope Tracker · Market",
    stat: gilt30.displayValue,
    label: "20-year nominal gilt yield. The long-end read on UK borrowing costs.",
    foot: ["Source · BoE IADB", shortDate(gilt30.observedAt)],
    ogPath: "/og/gilt-30y-high.png",
  } : null,
  mortRates ? {
    id: "mortgage",
    // Variant flexes by sign so a negative delta (households paying less than
    // at the comparator) doesn't paint in alarm orange. Positive → accent
    // (orange, "more expensive"). Negative → good (green, "cheaper").
    variant: mortRates.extraPerMonth > 0 ? "accent" : mortRates.extraPerMonth < 0 ? "good" : "",
    brand: "Tightrope Tracker · Households",
    stat: formatExtra(mortRates.extraPerMonth),
    label: `A month, on a £250k 25-year mortgage, vs the rate at the ${MORTGAGE_BUDGET_BASELINE_LABEL}. 2y fix now ${mortRates.currentRate.toFixed(2)}%.`,
    foot: ["Source · BoE IADB (IUMBV34)", shortDate(mortgage!.observedAt)],
    ogPath: "/og/mortgage-pressure.png",
  } : null,
  housingContrib ? {
    id: "housing",
    variant: "",
    brand: "Tightrope Tracker · Delivery",
    stat: housingDelivery ? `${Math.round(housingContrib.rawValue).toLocaleString("en-GB")}` : "—",
    label: "Net additional dwellings (latest MHCLG release). Government target: 305k a year by 2030/31.",
    foot: ["Source · MHCLG", shortDate(housingContrib.observedAt)],
    ogPath: "/og/delivery-housing.png",
  } : null,
];

const cards = allCards.filter((c): c is Card => c !== null);
---
<section class="section" id="share" aria-labelledby="share-title">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">Spread the data</span>
        <h2 class="sec-title" id="share-title" style="margin-top: 14px;">Shareable cards · updated nightly</h2>
        <p class="section-sub">Every card is auto-generated from the live data and pushed to a stable OG URL. Download, tweet, embed in your Substack.</p>
      </div>
    </div>

    <div class="share-grid">
      {cards.map((c) => (
        <a class={`share-card ${c.variant}`} href={`https://og.tightropetracker.uk${c.ogPath}`} rel="noopener" aria-label={`Open share image: ${c.brand}`}>
          <div class="sc-brand">{c.brand}</div>
          <div>
            <div class="sc-stat">{c.stat}</div>
            <div class="sc-label">{c.label}</div>
          </div>
          <div class="sc-foot"><span>{c.foot[0]}</span><span>{c.foot[1]}</span></div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.share-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.share-card {
  aspect-ratio: 1200 / 630;
  border-radius: 10px;
  padding: 24px 28px;
  display: flex; flex-direction: column; justify-content: space-between;
  position: relative;
  overflow: hidden;
  background: var(--bg-1);
  border: 1px solid var(--border);
  transition: transform 180ms;
  color: inherit;
}
.share-card:hover { transform: translateY(-3px); color: inherit; }
.share-card .sc-brand { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-2); }
.share-card .sc-stat { font-family: var(--font-serif); font-size: clamp(36px, 4vw, 56px); font-weight: 700; letter-spacing: -0.025em; line-height: 0.95; color: var(--ink-0); font-variant-numeric: tabular-nums; }
.share-card .sc-label { font-family: var(--font-serif); font-size: 15px; color: var(--ink-1); line-height: 1.35; max-width: 85%; margin-top: 8px; font-weight: 400; }
.share-card .sc-foot { display: flex; justify-content: space-between; align-items: center; font-family: var(--font-mono); font-size: 10px; color: var(--ink-2); letter-spacing: 0.05em; }
.share-card.critical { background: linear-gradient(135deg, color-mix(in srgb, var(--band-critical) 12%, transparent), var(--bg-1)); border-color: color-mix(in srgb, var(--band-critical) 35%, transparent); }
.share-card.critical .sc-stat { color: var(--band-critical); }
.share-card.accent { background: linear-gradient(135deg, color-mix(in srgb, var(--accent) 8%, transparent), var(--bg-1)); border-color: color-mix(in srgb, var(--accent) 30%, transparent); }
.share-card.accent .sc-stat { color: var(--accent); }
/* `good` variant — slack-green tint, used when a card's headline number is a
   positive outcome (e.g. mortgage cost falling vs comparator). Mirrors the
   OG `good` variant in apps/og/src/templates/components.tsx. */
.share-card.good { background: linear-gradient(135deg, color-mix(in srgb, var(--band-slack) 12%, transparent), var(--bg-1)); border-color: color-mix(in srgb, var(--band-slack) 35%, transparent); }
.share-card.good .sc-stat { color: var(--band-slack); }

.section-head {
  display: grid; grid-template-columns: 1fr auto; align-items: end; gap: 24px;
  margin-bottom: 40px;
}

@media (max-width: 920px) {
  .share-grid { grid-template-columns: 1fr; }
  .section-head { grid-template-columns: 1fr; }
}
</style>
