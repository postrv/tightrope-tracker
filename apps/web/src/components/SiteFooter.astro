---
import { bstTimestamp } from "~/lib/format.js";

interface Props {
  updatedAt?: string;
  /**
   * ISO timestamp of the freshest indicator observation. When provided, the
   * footer shows the observation timestamp as the primary "live" marker and
   * keeps the recompute heartbeat as a secondary line — so the visible
   * date can never lie about indicator-level freshness.
   */
  freshestAt?: string | null;
  /** When true, label the refresh timestamp as the last FRESH ingest rather
   *  than implying the data is live. */
  stale?: boolean;
}

const { updatedAt, freshestAt, stale = false } = Astro.props;
const recomputeTs = updatedAt ? bstTimestamp(updatedAt) : bstTimestamp(new Date());
const observationTs = freshestAt ? bstTimestamp(freshestAt) : null;
const refreshLabel = stale ? "Last fresh data" : "Latest data";
---
<footer class="site">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-col">
        <h4>About</h4>
        <p class="foot-about"><strong>Tightrope Tracker</strong> is an independent civic data project. Not affiliated with any political party or government body. All data is public and verifiable. Built by citizens who believe sunlight is the best disinfectant.<!-- --></p>
        <p class="foot-credits">Made by Laurence Avent and commissioned by <a href="https://lookingforgrowth.uk/" rel="noopener" target="_blank">Looking for Growth UK</a>, a grassroots non-party movement. Editorial independence preserved: figures are sourced from named publishers and every correction is logged.</p>
      </div>
      <div class="foot-col">
        <h4>The score</h4>
        <ul>
          <li><a href="/methodology">Methodology</a></li>
          <li><a href="/#market">Market Stability</a></li>
          <li><a href="/#fiscal">Fiscal Room</a></li>
          <li><a href="/#labour">Labour &amp; Living</a></li>
          <li><a href="/#delivery">Growth Delivery</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Use the data</h4>
        <ul>
          <li><a href="/explore">What-if simulator</a></li>
          <li><a href="/docs">API docs</a></li>
          <li><a href="https://api.tightropetracker.uk/api/v1/score" rel="noopener" target="_blank">Public API</a></li>
          <li><a href="/#action">Embed widgets</a></li>
          <li><a href="/corrections">Corrections log</a></li>
          <li><a href="/sources">Sources</a></li>
        </ul>
      </div>
      <div class="foot-col">
        <h4>Sources</h4>
        <ul>
          <li><a href="https://obr.uk" rel="noopener" target="_blank">OBR</a></li>
          <li><a href="https://ons.gov.uk" rel="noopener" target="_blank">ONS</a></li>
          <li><a href="https://bankofengland.co.uk" rel="noopener" target="_blank">Bank of England</a></li>
          <li><a href="https://dmo.gov.uk" rel="noopener" target="_blank">Debt Management Office</a></li>
          <li><a href="https://ifs.org.uk" rel="noopener" target="_blank">Institute for Fiscal Studies</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-motif" aria-hidden="true"></div>
    <div class="foot-bottom">
      <span>© 2026 Tightrope Tracker · MIT-licensed · source on <a href="https://github.com/postrv/tightrope-tracker" rel="noopener" target="_blank" class="gh-link"><svg class="gh-icon" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.63 7.63 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>GitHub</a></span>
      <span>
        {refreshLabel}: <span class={`refresh-ts${stale ? " stale" : ""}`}>{observationTs ?? recomputeTs}</span>
        {observationTs ? <span class="recompute-ts" title="Five-minutely recompute heartbeat — separate from the indicator-level data freshness shown above.">· recompute {recomputeTs}</span> : null}
      </span>
    </div>
  </div>
</footer>

<style>
footer.site { padding: 48px 0 64px; color: var(--ink-2); font-size: 12.5px; }
footer.site a { color: var(--ink-1); }
footer.site a:hover { color: var(--accent); }
.foot-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 36px; }
.foot-col h4 { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-3); margin: 0 0 14px; font-weight: 500; }
.foot-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; font-size: 13px; }
.foot-about { font-size: 13px; line-height: 1.6; max-width: 380px; }
.foot-about strong { color: var(--ink-0); font-family: var(--font-serif); font-weight: 400; }
.foot-credits { font-size: 12.5px; line-height: 1.6; max-width: 380px; margin-top: 12px; color: var(--ink-2); }
.foot-motif {
  height: 11px;
  margin: 0 0 24px;
  background-image:
    linear-gradient(var(--accent), var(--accent)),
    linear-gradient(var(--accent-cool), var(--accent-cool)),
    linear-gradient(var(--ink-0), var(--ink-0));
  background-position: 0 0, 0 4px, 0 8px;
  background-size: 100% 3px, 60% 3px, 30% 3px;
  background-repeat: no-repeat;
}
.foot-bottom { padding-top: 16px; display: flex; justify-content: space-between; gap: 20px; flex-wrap: wrap; }
.gh-link { display: inline-flex; align-items: center; gap: 4px; }
.gh-icon { width: 14px; height: 14px; vertical-align: -1px; flex-shrink: 0; }
.refresh-ts { font-family: var(--font-mono); color: var(--ink-1); }
.refresh-ts.stale { color: var(--band-critical); }
.recompute-ts { font-family: var(--font-mono); color: var(--ink-3); margin-left: 6px; font-size: 11px; }

@media (max-width: 920px) {
  .foot-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
}
</style>
