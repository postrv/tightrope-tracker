---
interface Props {
  score: number;
  /** If false, walker renders static (no sway, no parallax) at a representative lean. */
  animate?: boolean;
}

const { score, animate = true } = Astro.props;
const safeScore = Math.max(0, Math.min(100, score ?? 0));

// Maximum lateral sway amplitude (degrees) around the rope axis. Capped well
// below "fall" so even score 100 reads as struggling rather than fallen.
const MAX_SWAY = 30;
const targetAmp = MAX_SWAY * Math.pow(safeScore / 100, 1.4);
const label = Math.round(safeScore);

// Stability arc behind the walker shows three zones: green ±10°, amber to ±20°,
// red to ±30°. Each zone "lights up" once the walker's swept range reaches it,
// so the arc reads as a colour-coded gauge of how far the walker is reaching.
const amberLit = targetAmp > 9;
const redLit = targetAmp > 18;
// Opacities tuned for the warm cream backdrop: colour-coded zones need to
// read strongly against cream without overwhelming the walker silhouette.
const greenOpacity = 0.38;
const amberOpacity = amberLit ? 0.48 : 0.14;
const redOpacity = redLit ? 0.50 : 0.12;

// Speed multiplier on the sway: ~1× at score 0, ~2.8× at score 100. High
// instability reads as frantic micro-corrections; low instability stays calm.
const speedMult = 1 + Math.pow(safeScore / 100, 1.5) * 1.8;

// Static pose (used when animate=false, e.g. embed): a representative
// mid-sway lean so the still image conveys instability instead of standing
// perfectly vertical against an active red arc.
const staticAngle = animate ? 0 : targetAmp * 0.55;
---
<div
  class="tightrope-walker"
  data-animate={animate ? "true" : "false"}
  data-score={safeScore}
  data-amp={targetAmp.toFixed(3)}
  data-speed={speedMult.toFixed(3)}
  aria-label={`Tightrope walker, viewed from behind on a wire receding into the distance. Lateral sway amplitude reflects instability score ${label} of 100.`}
  role="img"
>
  <div class="perspective">
    <div class="scene">
      <!-- Distant atmospheric backdrop, on a vertical plane far behind
           everything. Warm cream sky fading through soft tan to an ember
           horizon glow -- the "dawn over the City" mood the LFG palette is
           built around. The dark ridge silhouette anchors the horizon and
           gives the walker something solid to be framed against. -->
      <div class="layer bg-layer">
        <svg viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
          <defs>
            <radialGradient id="tw-vp-glow" cx="0.5" cy="0.62" r="0.55">
              <stop offset="0" stop-color="#FE5500" stop-opacity="0.38"/>
              <stop offset="0.45" stop-color="#EE9944" stop-opacity="0.18"/>
              <stop offset="1" stop-color="#EE9944" stop-opacity="0"/>
            </radialGradient>
            <linearGradient id="tw-sky" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#F4EEE0"/>
              <stop offset="0.45" stop-color="#EBE3D0"/>
              <stop offset="0.82" stop-color="#E0D0A6"/>
              <stop offset="1" stop-color="#C98A3E"/>
            </linearGradient>
          </defs>
          <rect x="-200" y="-100" width="1000" height="700" fill="url(#tw-sky)"/>
          <!-- Ember halo around the vanishing point. -->
          <ellipse cx="300" cy="305" rx="320" ry="80" fill="url(#tw-vp-glow)"/>
          <!-- Distant city ridge: low silhouette against the warm sky.
               Dark enough to read as the skyline, warm enough to sit in
               the LFG palette. -->
          <path d="M 0 302 Q 70 290 140 298 Q 190 304 240 294 L 260 294 L 260 300 L 275 300 L 275 288 L 290 288 L 290 300 L 310 300 L 310 290 L 325 290 L 325 300 L 340 300 L 340 294 L 360 294 Q 420 302 480 292 Q 540 286 600 298 L 600 320 L 0 320 Z" fill="#2A2825" opacity="0.92"/>
          <!-- Far anchor (where the rope ties off in the distance) -->
          <rect x="284" y="286" width="32" height="4" fill="#4A4540"/>
          <rect x="284" y="290" width="32" height="10" fill="#1A1815"/>
        </svg>
      </div>

      <!-- Rope as a flat plane laid into 3D depth (rotated nearly horizontal) -->
      <div class="layer rope-layer">
        <svg viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="tw-rope" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#C94400" stop-opacity="0.55"/>
              <stop offset="0.35" stop-color="#FE5500" stop-opacity="0.90"/>
              <stop offset="1" stop-color="#EE9944"/>
            </linearGradient>
          </defs>
          <!-- Rope: thin stripe down the centre. Layer is rotated nearly flat
               so this becomes a wire receding from the foreground (bottom) to
               the vanishing point (top, near horizon). Atmospheric fade dims
               the far end. -->
          <rect x="294" y="0" width="12" height="500" fill="url(#tw-rope)" rx="4"/>
          <rect x="298.5" y="0" width="3" height="500" fill="#EE9944" opacity="0.55"/>
          <!-- Evenly-spaced wraps along the rope. In perspective these visibly
               compress toward the vanishing point — a strong depth cue. -->
          <g fill="#C94400" opacity="0.85">
            <rect x="291" y="60"  width="18" height="3" rx="1"/>
            <rect x="291" y="120" width="18" height="3" rx="1"/>
            <rect x="291" y="190" width="18" height="3" rx="1"/>
            <rect x="291" y="270" width="18" height="3" rx="1"/>
            <rect x="291" y="360" width="18" height="3" rx="1"/>
            <rect x="291" y="460" width="18" height="3" rx="1"/>
          </g>
        </svg>
      </div>

      <!-- Walker stays on a vertical plane in the foreground -->
      <div class="layer walker-layer">
        <svg viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg">
          <!-- Stability arc: ±30° fan behind walker, colour-coded by zone.
               Centre at (300, 430) shared with the walker pivot, radius 140.
               Green core ±10°, amber to ±20°, red to ±30°. Each zone's opacity
               lifts once the walker's swept range reaches it. -->
          <g class="stability-arc">
            <path d="M 300 430 L 230 308.76 A 140 140 0 0 1 252.12 298.45 Z" fill="#C84B3C" opacity={redOpacity}/>
            <path d="M 300 430 L 252.12 298.45 A 140 140 0 0 1 275.69 292.13 Z" fill="#EE9944" opacity={amberOpacity}/>
            <path d="M 300 430 L 275.69 292.13 A 140 140 0 0 1 324.31 292.13 Z" fill="#5FB27C" opacity={greenOpacity}/>
            <path d="M 300 430 L 324.31 292.13 A 140 140 0 0 1 347.88 298.45 Z" fill="#EE9944" opacity={amberOpacity}/>
            <path d="M 300 430 L 347.88 298.45 A 140 140 0 0 1 370 308.76 Z" fill="#C84B3C" opacity={redOpacity}/>
            <!-- Soft outer rim for definition -->
            <path d="M 230 308.76 A 140 140 0 0 1 370 308.76" stroke="#3A3630" stroke-width="0.6" fill="none" opacity="0.45"/>
            <!-- Vertical reference line at 0° (stable) -->
            <line x1="300" y1="430" x2="300" y2="290" stroke="#7A7468" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.3"/>
          </g>

          <g class="walker" transform={`translate(300, 430) rotate(${staticAngle.toFixed(2)})`}>
            <!-- Walker silhouette in ink-0 black -- high contrast against the
                 warm cream sky, which is the LFG "black figure on cream
                 panel" motif translated into this illustration. Balance pole
                 same ink so the whole figure reads as one shape. -->
            <!-- Balance pole, gentle droop at tips -->
            <path d="M -140 -54 Q 0 -49 140 -54" stroke="#000000" stroke-width="2.6" fill="none" stroke-linecap="round"/>
            <circle cx="-140" cy="-54" r="3" fill="#000000"/>
            <circle cx="140" cy="-54" r="3" fill="#000000"/>

            <!-- Head (no face — rear view) -->
            <circle cx="0" cy="-114" r="10.5" fill="#000000"/>
            <line x1="0" y1="-104" x2="0" y2="-50" stroke="#000000" stroke-width="3.2" stroke-linecap="round"/>
            <line x1="-16" y1="-94" x2="16" y2="-94" stroke="#000000" stroke-width="2.8" stroke-linecap="round"/>
            <!-- Arms to balance pole -->
            <line x1="-16" y1="-94" x2="-140" y2="-54" stroke="#000000" stroke-width="2.8" stroke-linecap="round"/>
            <line x1="16" y1="-94" x2="140" y2="-54" stroke="#000000" stroke-width="2.8" stroke-linecap="round"/>
            <!-- Hips -->
            <line x1="-10" y1="-50" x2="10" y2="-50" stroke="#000000" stroke-width="2.8" stroke-linecap="round"/>
            <!-- Legs -->
            <line x1="-10" y1="-50" x2="-4" y2="0" stroke="#000000" stroke-width="3.2" stroke-linecap="round"/>
            <line x1="10" y1="-50" x2="3" y2="0" stroke="#000000" stroke-width="3.2" stroke-linecap="round"/>
            <!-- Foot shadow on rope -->
            <ellipse cx="0" cy="3" rx="11" ry="1.6" fill="#000000" opacity="0.4"/>
          </g>
        </svg>
      </div>

      <!-- UI label -->
      <div class="layer ui-layer">
        <svg viewBox="0 0 600 500" xmlns="http://www.w3.org/2000/svg">
          <text x="300" y="488" text-anchor="middle" font-family="IBM Plex Mono" font-size="11" fill="#7A7468" letter-spacing="3">INSTABILITY · {label}/100</text>
        </svg>
      </div>
    </div>
  </div>
</div>

<style>
.tightrope-walker {
  position: relative;
  width: 100%;
  aspect-ratio: 6 / 5;
  max-width: 480px;
  margin-left: auto;
  overflow: hidden;
  border-radius: 6px;
  --mx: 0;
  --my: 0;
}
.perspective {
  position: absolute;
  inset: 0;
  perspective: 700px;
  perspective-origin: 50% 8%;
}
.scene {
  position: absolute;
  inset: 0;
  transform-style: preserve-3d;
  transform: rotateY(calc(var(--mx) * 8deg)) rotateX(calc(var(--my) * -3deg));
  will-change: transform;
}
.layer { position: absolute; inset: 0; transform-style: preserve-3d; }
.layer svg { width: 100%; height: 100%; display: block; overflow: visible; }

/* BG: vertical plane, pushed back so it never occludes the receding rope */
.bg-layer { transform: translateZ(-700px) scale(2.4); }

/* Rope: flat plane laid nearly horizontal, hinged at its bottom edge.
   After rotation, the SVG's top edge recedes into the distance
   while its bottom stays at the foreground. */
.rope-layer {
  transform-origin: 50% 100%;
  transform: translateZ(0) rotateX(72deg);
}

/* Walker: vertical plane in foreground */
.walker-layer { transform: translateZ(20px); }

/* Label: vertical plane, very front */
.ui-layer { transform: translateZ(60px); }

@media (prefers-reduced-motion: reduce) {
  .scene { transform: none; }
}
@media (hover: none), (pointer: coarse) {
  .scene { transform: none; }
}
</style>

<script is:inline nonce={Astro.locals.cspNonce}>
(() => {
  const reduce = window.matchMedia?.("(prefers-reduced-motion: reduce)").matches ?? false;
  const fineHover = window.matchMedia?.("(hover: hover) and (pointer: fine)").matches ?? false;

  const all = document.querySelectorAll('.tightrope-walker[data-animate="true"]');
  all.forEach((viz) => {
    const ampDeg = Number(viz.dataset.amp ?? "0");
    const speedMult = Number(viz.dataset.speed ?? "1");
    const walker = viz.querySelector(".walker");
    if (!walker) return;

    if (reduce) {
      // Reduced motion: hold the walker at a representative static lean
      // proportional to the swept amplitude, so the colour-coded arc still
      // makes sense without any motion.
      const restAngle = ampDeg * 0.55;
      walker.setAttribute("transform", `translate(300, 430) rotate(${restAngle.toFixed(2)})`);
      return;
    }

    if (fineHover) {
      let pendingMx = 0, pendingMy = 0, queued = false;
      const flush = () => {
        viz.style.setProperty("--mx", pendingMx.toFixed(3));
        viz.style.setProperty("--my", pendingMy.toFixed(3));
        queued = false;
      };
      viz.addEventListener("pointermove", (e) => {
        const rect = viz.getBoundingClientRect();
        pendingMx = ((e.clientX - rect.left) / rect.width) * 2 - 1;
        pendingMy = ((e.clientY - rect.top) / rect.height) * 2 - 1;
        if (!queued) { queued = true; requestAnimationFrame(flush); }
      });
      viz.addEventListener("pointerleave", () => {
        pendingMx = 0; pendingMy = 0;
        if (!queued) { queued = true; requestAnimationFrame(flush); }
      });
    }

    const w1 = 0.00092;
    const w2 = 0.00213;
    const w3 = 0.00497;
    const phi2 = 1.7;
    const phi3 = 0.5;
    const norm = 1 + 0.55 + 0.25;
    const t0 = performance.now();
    const settleDur = 1100;

    function frame(t) {
      const elapsed = t - t0;
      const settle = Math.min(1, elapsed / settleDur);
      const eased = 1 - Math.pow(1 - settle, 3);
      const sweptT = elapsed * speedMult;
      const wave =
        Math.sin(sweptT * w1) +
        Math.sin(sweptT * w2 + phi2) * 0.55 +
        Math.sin(sweptT * w3 + phi3) * 0.25;
      const angle = (wave / norm) * ampDeg * eased;
      walker.setAttribute("transform", `translate(300, 430) rotate(${angle.toFixed(2)})`);
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  });
})();
</script>
