---
import type { TodayMovement } from "@tightrope/shared";
import Sparkline from "./charts/Sparkline.astro";
import ProvenanceBadge from "./ProvenanceBadge.astro";
import { shortDate } from "~/lib/format.js";
import { ageBand, ageShort } from "~/lib/freshness.js";

interface Props {
  movements: TodayMovement[];
}

const { movements } = Astro.props;
const now = Date.now();
---
<section class="today" id="today" aria-labelledby="today-title">
  <div class="container">
    <h2 class="sec-title" id="today-title">What moved today</h2>
    <p class="today-sub">Updated every five minutes during UK market hours. Hover any tile for the full source and timestamp.</p>

    {movements.length === 0 ? (
      <p class="today-empty">Intraday feed quiet. The next refresh runs at the top of the hour.</p>
    ) : (
      <div class="today-scroll">
        {movements.slice(0, 8).map((m) => {
          const colour = m.worsening ? "var(--band-acute)" : "var(--band-slack)";
          const band = ageBand(m.observedAt, m.indicatorId, now);
          const ageLabel = ageShort(m.observedAt, now);
          return (
            <div class="today-card" data-tip={`Observed ${m.observedAt}`}>
              <div class="label-row">
                <span class="label">{m.label}</span>
                <ProvenanceBadge indicatorId={m.indicatorId} compact />
              </div>
              <span class="val">{m.displayValue}</span>
              <span class={`chg ${m.worsening ? "up" : "dn"}`}>{m.changeDisplay}</span>
              <Sparkline
                series={m.sparkline && m.sparkline.length ? m.sparkline : [0, 0]}
                stroke={colour}
                width={100}
                height={28}
                ariaLabel={`${m.label} sparkline`}
              />
              <span class="gloss">{m.gloss}</span>
              <span
                class={`age-stamp age-${band}`}
                title={`Indicator observation: ${m.observedAt}. Cadence band: ${band}.`}
                aria-label={`Observed on ${shortDate(m.observedAt)}, ${band}`}
              >
                <span class="age-dot" aria-hidden="true"></span>
                <span class="age-date">{shortDate(m.observedAt)}</span>
                {band === "stale" || band === "ageing" ? <span class="age-rel">· {ageLabel} ago</span> : null}
              </span>
            </div>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
.today { padding: 48px 0; border-top: 1px solid var(--border-soft); border-bottom: 1px solid var(--border-soft); background: var(--bg-1); }
.today h2.sec-title {
  font-size: 32px;
}
.today-sub { color: var(--ink-2); font-size: 13.5px; margin: 0 0 24px; }
.today-empty { color: var(--ink-2); font-family: var(--font-mono); font-size: 12px; padding: 20px 0; }

.today-scroll {
  display: grid; grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 12px;
}
.today-card {
  background: var(--bg-0);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 16px;
  display: flex; flex-direction: column; gap: 8px;
  transition: border-color 180ms, transform 180ms;
  min-height: 130px;
}
.today-card { position: relative; }
.today-card::after {
  content: attr(data-tip);
  position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%);
  padding: 4px 8px; border-radius: 4px;
  background: var(--ink-0); color: var(--bg-0);
  font-family: var(--font-mono); font-size: 10px; white-space: nowrap;
  opacity: 0; pointer-events: none; transition: opacity 150ms;
  margin-bottom: 6px; z-index: 10;
}
.today-card:hover::after { opacity: 1; }
.today-card:hover { border-color: var(--accent-dim); transform: translateY(-2px); }
.today-card .label-row { display: flex; align-items: center; justify-content: space-between; gap: 6px; }
.today-card .label { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2); }
.today-card .val { font-family: var(--font-mono); font-size: 20px; font-weight: 500; color: var(--ink-0); letter-spacing: -0.01em; font-variant-numeric: tabular-nums; }
.today-card .chg { font-family: var(--font-mono); font-size: 11.5px; }
.today-card .chg.up { color: var(--band-acute); }
.today-card .chg.dn { color: var(--band-slack); }
.today-card .gloss { font-size: 11px; color: var(--ink-1); line-height: 1.4; margin-top: auto; }

/* Age stamp: visible date + colour-coded dot. The date is read at a glance;
   the dot turns amber at half the indicator's freshness window and red past
   it, so a 10-day-old daily observation can't masquerade as live. The
   thresholds come from INDICATORS[id].maxStaleMs — fresh on a monthly fixture
   means something different to fresh on a daily yield. */
.age-stamp {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.04em;
  color: var(--ink-2);
  padding-top: 4px;
  border-top: 1px solid var(--border-soft);
}
.age-stamp .age-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--ink-3);
  flex-shrink: 0;
}
.age-stamp.age-fresh .age-dot { background: var(--band-slack); }
.age-stamp.age-ageing .age-dot { background: var(--band-strain); }
.age-stamp.age-ageing { color: var(--ink-1); }
.age-stamp.age-stale .age-dot { background: var(--band-acute); }
.age-stamp.age-stale { color: var(--band-acute); }
.age-stamp.age-unknown .age-dot { background: var(--ink-3); }
.age-rel { color: inherit; opacity: 0.85; }

@media (max-width: 920px) {
  .today-scroll { grid-template-columns: repeat(2, 1fr); }
}
</style>
