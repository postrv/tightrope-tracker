---
import type { ScoreBand } from "@tightrope/shared";

interface Props {
  band?: ScoreBand;
  updatedAt?: string;
  /**
   * If true, render a minimal version without section links — used on
   * non-homepage pages where in-page anchors don't resolve.
   */
  compact?: boolean;
}

const { band, updatedAt, compact = false } = Astro.props;
const dotColour = band
  ? `var(--band-${band === "slack" ? "slack" : band === "steady" ? "steady" : band === "strained" ? "strain" : band === "acute" ? "acute" : "critical"})`
  : "var(--band-acute)";

const hh = updatedAt
  ? new Date(updatedAt).toISOString().substring(11, 16) + " UTC"
  : "";
---
<nav class="top">
  <div class="container">
    <a href="/" class="brand" aria-label="Tightrope Tracker home">
      <span class="logo" aria-hidden="true"></span>
      <span>Tightrope Tracker</span>
    </a>
    {compact ? (
      <ul>
        <li><a href="/#market">Market</a></li>
        <li><a href="/#fiscal">Fiscal</a></li>
        <li><a href="/#labour">Labour</a></li>
        <li><a href="/#delivery">Delivery</a></li>
        <li><a href="/methodology">Method</a></li>
        <li><a href="/sources">Sources</a></li>
      </ul>
    ) : (
      <ul>
        <li><a href="#market">Market</a></li>
        <li><a href="#fiscal">Fiscal</a></li>
        <li><a href="#labour">Labour</a></li>
        <li><a href="#delivery">Delivery</a></li>
        <li><a href="#timeline">Timeline</a></li>
        <li><a href="#action">Act</a></li>
        <li><a href="/methodology">Method</a></li>
      </ul>
    )}
    <span class="live-chip" aria-live="polite">
      <span class="dot" style={`background: ${dotColour}; --pulse: ${dotColour};`}></span>
      {hh ? `Live · Updated ${hh}` : "Live · Awaiting first ingestion"}
    </span>
  </div>
</nav>

<style>
nav.top {
  position: sticky; top: 0; z-index: 50;
  background: rgba(11, 13, 16, 0.82);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--border-soft);
}
nav.top .container { display: flex; align-items: center; justify-content: space-between; height: 62px; gap: 20px; }
.brand { display: flex; align-items: center; gap: 12px; font-family: var(--font-serif); font-weight: 500; font-size: 18px; letter-spacing: -0.01em; }
.brand .logo {
  width: 28px; height: 28px;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dim) 100%);
  border-radius: 4px;
  position: relative;
  overflow: hidden;
}
.brand .logo::after {
  content: ""; position: absolute; inset: 0;
  background: linear-gradient(135deg, transparent 49%, var(--bg-0) 49.5%, var(--bg-0) 50.5%, transparent 51%);
}
nav.top ul { display: flex; gap: 28px; list-style: none; margin: 0; padding: 0; font-size: 13px; color: var(--ink-1); }
nav.top ul a { transition: color 180ms; }
.live-chip {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ink-1);
  padding: 4px 10px 4px 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  white-space: nowrap;
}
.live-chip .dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--band-acute);
  box-shadow: 0 0 0 0 rgba(217, 120, 56, 0.6);
  animation: pulse 2.2s infinite;
}
@keyframes pulse {
  0%   { box-shadow: 0 0 0 0 rgba(217, 120, 56, 0.6); }
  70%  { box-shadow: 0 0 0 8px rgba(217, 120, 56, 0); }
  100% { box-shadow: 0 0 0 0 rgba(217, 120, 56, 0); }
}
@media (max-width: 920px) {
  nav.top ul { display: none; }
}
</style>
