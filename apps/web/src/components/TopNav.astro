---
import type { ScoreBand } from "@tightrope/shared";

interface Props {
  band?: ScoreBand;
  updatedAt?: string;
  /**
   * ISO timestamp of the freshest indicator observation. When provided, the
   * chip displays "Data · DD MMM HH:MM UTC" anchored to this — the value the
   * viewer actually wants to know about. `updatedAt` (recompute heartbeat)
   * is preserved as the title attribute for ops debugging.
   */
  freshestAt?: string | null;
  /** When true, the latest reading is past its staleness window -- render a
   *  "Stale" chip instead of the live "Updated HH:MM" chip. */
  stale?: boolean;
  /**
   * If true, render a minimal version without section links — used on
   * non-homepage pages where in-page anchors don't resolve.
   */
  compact?: boolean;
}

const { band, updatedAt, freshestAt, stale = false, compact = false } = Astro.props;
const dotColour = stale
  ? "var(--band-critical)"
  : band
    ? `var(--band-${band === "slack" ? "slack" : band === "steady" ? "steady" : band === "strained" ? "strain" : band === "acute" ? "acute" : "critical"})`
    : "var(--band-acute)";

// Display anchor: prefer the freshest indicator observation over the recompute
// heartbeat. The recompute timestamp ticks every 5 minutes regardless of
// whether the underlying data has moved, so showing it as "Updated HH:MM" is
// misleading-fresh when an upstream fixture is days stale.
const displayAt = freshestAt ?? updatedAt;
const MONTH_SHORT = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
function formatChip(iso: string | undefined | null): string {
  if (!iso) return "";
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return "";
  const day = d.getUTCDate();
  const mon = MONTH_SHORT[d.getUTCMonth()];
  const hh = d.toISOString().substring(11, 16);
  return `${day} ${mon} ${hh} UTC`;
}
const chipStamp = formatChip(displayAt);

// Short "2h", "3d" style age string so the stale chip conveys how old the
// last-known reading is without eating the whole nav bar.
function ageShort(iso: string | undefined | null): string {
  if (!iso) return "";
  const ms = Date.now() - Date.parse(iso);
  if (!Number.isFinite(ms) || ms < 0) return "";
  const hours = Math.floor(ms / 3_600_000);
  if (hours < 1) return `${Math.max(1, Math.floor(ms / 60_000))}m`;
  if (hours < 48) return `${hours}h`;
  return `${Math.floor(hours / 24)}d`;
}
const age = ageShort(displayAt);
const recomputeChip = formatChip(updatedAt);
---
{(() => {
  const links = compact
    ? [
        { href: "/#market", label: "Market" },
        { href: "/#fiscal", label: "Fiscal" },
        { href: "/#labour", label: "Labour" },
        { href: "/#delivery", label: "Delivery" },
        { href: "/explore", label: "Explore" },
        { href: "/methodology", label: "Method" },
        { href: "/sources", label: "Sources" },
        { href: "/docs", label: "API" },
      ]
    : [
        { href: "#market", label: "Market" },
        { href: "#fiscal", label: "Fiscal" },
        { href: "#labour", label: "Labour" },
        { href: "#delivery", label: "Delivery" },
        { href: "#timeline", label: "Timeline" },
        { href: "/explore", label: "Explore" },
        { href: "#action", label: "Act" },
        { href: "/methodology", label: "Method" },
        { href: "/sources", label: "Sources" },
        { href: "/docs", label: "API" },
      ];
  return (
    <nav class="top">
      <div class="container">
        <a href="/" class="brand" aria-label="Tightrope Tracker home">
          <span class="logo" aria-hidden="true"></span>
          <span class="brand-text">tightrope tracker</span>
        </a>
        <ul class="primary">
          {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
        </ul>
        <span
          class={`live-chip${stale ? " stale" : ""}`}
          aria-live="polite"
          title={stale
            ? `Last fresh reading ${chipStamp}. Recompute heartbeat ${recomputeChip}.`
            : `Stamp = freshest indicator observation. Recompute heartbeat ${recomputeChip}. Auto-ingest cadences range from five-minutely (BoE rates) to monthly (ONS prints).`}
        >
          <span class="dot" style={`background: ${dotColour}; --pulse: ${dotColour};`}></span>
          {stale
            ? `Stale · last fresh ${age || chipStamp}`
            : chipStamp
              ? `Data · ${chipStamp}`
              : "Auto · Awaiting first ingestion"}
        </span>
        <button class="hamburger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav-panel" data-nav-toggle>
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="mobile-panel" id="mobile-nav-panel" hidden>
        <ul>
          {links.map((l) => (<li><a href={l.href} data-nav-link>{l.label}</a></li>))}
        </ul>
      </div>
    </nav>
  );
})()}

<script>
(() => {
  const btn = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  const panel = document.getElementById("mobile-nav-panel");
  if (!btn || !panel) return;
  function setOpen(open: boolean) {
    btn!.setAttribute("aria-expanded", String(open));
    if (open) panel!.removeAttribute("hidden");
    else panel!.setAttribute("hidden", "");
    btn!.classList.toggle("open", open);
  }
  btn.addEventListener("click", () => {
    setOpen(btn.getAttribute("aria-expanded") !== "true");
  });
  panel.querySelectorAll<HTMLAnchorElement>("[data-nav-link]").forEach((a) => {
    a.addEventListener("click", () => setOpen(false));
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });
})();
</script>

<style>
nav.top {
  position: sticky; top: 0; z-index: 50;
  background: color-mix(in srgb, var(--bg-0) 82%, transparent);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--border);
}
nav.top .container { display: flex; align-items: center; justify-content: space-between; height: 62px; gap: 20px; }
.brand { display: flex; align-items: center; gap: 12px; font-family: var(--font-serif); font-weight: 700; font-size: 18px; letter-spacing: -0.02em; color: var(--ink-0); }
.brand-text { line-height: 1; }
.brand .logo {
  width: 28px; height: 20px;
  background-image:
    linear-gradient(var(--accent), var(--accent)),
    linear-gradient(var(--accent-cool), var(--accent-cool)),
    linear-gradient(var(--ink-0), var(--ink-0));
  background-position: 0 1px, 0 8px, 0 15px;
  background-size: 28px 4px, 20px 4px, 12px 4px;
  background-repeat: no-repeat;
  border-radius: 0;
  flex-shrink: 0;
}
nav.top ul.primary { display: flex; gap: 28px; list-style: none; margin: 0; padding: 0; font-size: 13px; color: var(--ink-1); text-transform: lowercase; letter-spacing: -0.005em; }
nav.top ul a { transition: color 180ms; }
.hamburger {
  display: none;
  background: transparent; border: 1px solid var(--border);
  border-radius: 8px;
  width: 38px; height: 38px;
  padding: 0;
  cursor: pointer;
  flex-direction: column; justify-content: center; align-items: center; gap: 4px;
}
.hamburger span {
  display: block; width: 18px; height: 1.5px;
  background: var(--ink-0);
  border-radius: 1px;
  transition: transform 180ms, opacity 180ms;
}
.hamburger.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }
.mobile-panel {
  display: none;
  background: var(--bg-0);
  border-bottom: 1px solid var(--border-soft);
}
.mobile-panel ul {
  list-style: none; margin: 0;
  padding: 8px 20px 16px;
  display: flex; flex-direction: column; gap: 0;
}
.mobile-panel ul li { border-bottom: 1px solid var(--border-soft); }
.mobile-panel ul li:last-child { border-bottom: 0; }
.mobile-panel ul a {
  display: block; padding: 14px 4px;
  font-family: var(--font-mono); font-size: 13px;
  letter-spacing: 0.05em; color: var(--ink-1);
}
.mobile-panel ul a:hover { color: var(--accent); }
.live-chip {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ink-1);
  padding: 4px 10px 4px 8px;
  border: 1px solid var(--border);
  border-radius: 999px;
  white-space: nowrap;
}
.live-chip.stale {
  color: var(--band-critical);
  border-color: var(--band-critical);
  background: color-mix(in srgb, var(--band-critical) 10%, transparent);
}
.live-chip.stale .dot { animation: none; }
.live-chip .dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--band-acute);
  box-shadow: 0 0 0 0 rgba(254, 85, 0, 0.6);
  animation: pulse 2.2s infinite;
}
@keyframes pulse {
  0%   { box-shadow: 0 0 0 0 rgba(254, 85, 0, 0.6); }
  70%  { box-shadow: 0 0 0 8px rgba(254, 85, 0, 0); }
  100% { box-shadow: 0 0 0 0 rgba(254, 85, 0, 0); }
}
@media (max-width: 920px) {
  nav.top .container { gap: 12px; }
  nav.top ul.primary { display: none; }
  .hamburger { display: inline-flex; }
  .mobile-panel:not([hidden]) { display: block; }
  .live-chip { font-size: 10px; padding: 3px 8px 3px 7px; letter-spacing: 0.06em; }
}
@media (max-width: 480px) {
  .live-chip { display: none; }
}
</style>
