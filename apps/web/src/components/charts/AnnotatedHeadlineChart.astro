---
/**
 * Server-rendered SVG line chart of the headline Tightrope Score over time,
 * with timeline-event markers snapped to the nearest history point.
 *
 * Designed to be the homepage's "long view" — sits below the hero, shows
 * how the score has moved across the visible window, and pins the events
 * that drove the moves so the chart reads at a glance.
 *
 * Pure SVG, no client JS. Tooltips are CSS `:focus-within`/`:hover` only,
 * so the chart degrades gracefully and meets the <5KB JS budget by
 * shipping zero JS for the chart itself. Each event marker is keyboard-
 * focusable (`tabindex="0"`) and has a per-marker `aria-label`. The SVG
 * element itself carries a numeric ARIA summary so screen-reader users
 * never have to "read" a path.
 */
import type { ScoreHistory } from "@tightrope/shared";
import type { TimelineEvent, TimelineCategory } from "@tightrope/shared/timeline";
import { BANDS, bandFor, PILLAR_ORDER, PILLARS } from "@tightrope/shared";
import { pathFromSeries, shortDate } from "~/lib/format.js";
import { mapEventsToChart } from "~/lib/chartAnnotations.js";
import { safeHref } from "~/lib/safeHref.js";

interface Props {
  history: ScoreHistory;
  events: readonly TimelineEvent[];
  width?: number;
  height?: number;
  /** When true, render four faint pillar lines under the headline series. Off by default. */
  showPillars?: boolean;
}

const {
  history,
  events,
  width = 880,
  height = 320,
  showPillars = false,
} = Astro.props;

// --- layout constants -----------------------------------------------------
// Padding leaves room for left axis labels (0..100), bottom date ticks, and
// two rows of permanent event labels above + two rows below the plot. The
// extra top/bottom space is what lets dense Budget-clustered events stagger
// across multiple lanes instead of piling up in two parity rows.
const padL = 44;
const padR = 16;
const padT = 30;
const padB = 48;
const plotW = width - padL - padR;
const plotH = height - padT - padB;
// Per-lane y-anchors for the four-row label layout. Two lanes sit in padT,
// two in padB. Each holds one label per chart-x-position before spilling to
// the next lane.
const LABEL_LANES = [
  { y: padT - 18, above: true },   // above row 0 — closest to plot
  { y: padT - 4,  above: true },   // above row 1 — closer to top
  { y: padT + plotH + 14, above: false }, // below row 0
  { y: padT + plotH + 28, above: false }, // below row 1 (above date ticks)
] as const;

// --- band-tinted background regions and y-axis ticks ----------------------
// We anchor the y-axis to the canonical band boundaries (0, 20, 40, 60, 80, 100)
// rather than the data's min/max so the chart's vertical position is
// directly comparable across reads — a 70 in March is the same height as
// a 70 in April. Boundaries come from BANDS so any future re-banding
// flows through automatically.
function yFor(score: number): number {
  // 0 = bottom of plot (worst), 100 = top of plot (best). Higher score
  // pushes the line UP because higher = more room to move.
  const clamped = Math.max(0, Math.min(100, score));
  return padT + plotH - (clamped / 100) * plotH;
}

// Canonical boundaries for grid lines and band regions. We append 100 as
// the upper bound — BANDS gives [0,20), [20,40), [40,60), [60,80), [80,101)
// so the unique min values + 100 give us the full fence.
const boundaries: readonly number[] = [
  ...new Set(BANDS.map((b) => b.min)),
  100,
];
const yTicks = boundaries.map((v) => ({ value: v, y: yFor(v) }));

// Pre-compute band-tinted background regions. Done in the frontmatter so
// the template can render with a clean `.map()` — Astro's compiler is
// strict about early-return patterns inside JSX expressions.
const bandRegions = BANDS.flatMap((band) => {
  const top = yFor(Math.min(100, band.max));
  const bottom = yFor(band.min);
  const h = bottom - top;
  if (h <= 0) return [];
  return [{ y: top, h, colourToken: band.colourToken }];
});

// --- headline path --------------------------------------------------------
const points = history.points;
const headlineSeries = points.map((p) => p.headline);
const latestHeadline = headlineSeries.length ? headlineSeries[headlineSeries.length - 1]! : 0;
const accentBand = bandFor(latestHeadline);

// pathFromSeries normalises the y-axis to the data range; we want a fixed
// 0..100 scale so band regions line up. Build the path manually using yFor.
function pointsToPath(series: readonly number[]): string {
  if (series.length === 0) return "";
  if (series.length === 1) {
    const x = padL + plotW / 2;
    return `M${x.toFixed(2)},${yFor(series[0]!).toFixed(2)}`;
  }
  return series
    .map((v, i) => {
      const x = padL + (i / (series.length - 1)) * plotW;
      const y = yFor(v);
      return `${i === 0 ? "M" : "L"}${x.toFixed(2)},${y.toFixed(2)}`;
    })
    .join(" ");
}
const headlineD = pointsToPath(headlineSeries);

// Optional faint pillar lines — useful on the long-composite page; the
// homepage uses the default `showPillars=false`.
const pillarPaths = showPillars
  ? PILLAR_ORDER.map((p) => ({
      id: p,
      label: PILLARS[p].shortTitle,
      d: pointsToPath(points.map((pt) => pt.pillars[p] ?? 0)),
    }))
  : [];

// --- annotations ----------------------------------------------------------
const annotations = mapEventsToChart(history, events);

/**
 * Permanent labels: which annotations get an always-visible name above or
 * below the chart line. We restrict to fiscal + geopolitical events because
 * those are the moves the public will recognise (Budgets, GE, conflict
 * shocks). Monetary / policy / delivery still get a hover-tooltip dot.
 *
 * Titles are abbreviated to keep the SVG legible — the full title remains
 * accessible via the tooltip.
 */
const LABEL_CATEGORIES = new Set<TimelineCategory>(["fiscal", "geopolitical"]);
function abbreviateEventTitle(title: string): string {
  // Conservative truncation: split on the first comma/colon/dash, keep
  // the head clause, then trim to a hard cap so a label never blows the
  // chart width on mobile.
  const head = title.split(/[,:—–-]/, 1)[0]!.trim();
  return head.length > 18 ? `${head.slice(0, 17)}…` : head;
}
const majorAnnotations = annotations.filter((a) =>
  LABEL_CATEGORIES.has(a.event.category),
);

// --- label collision-resolving placement ----------------------------------
// The previous algorithm staggered labels above/below by index parity, which
// piles up two adjacent fiscal events on the same line whenever they happen
// to share parity (e.g. a Budget plus the OBR commentary on the same week).
// Pack into 4 lanes greedily by xRatio, dropping any label that doesn't fit
// — the marker dot remains, so the event is still readable on hover, but the
// chart never collapses into stacked overlapping text.
const LABEL_CHAR_WIDTH = 6.2; // ~10.5px monospace, conservative
const LABEL_GAP_PX = 6;

interface PlacedLabel {
  annotation: typeof majorAnnotations[number];
  cx: number;
  cy: number;
  labelX: number;
  labelY: number;
  anchor: "start" | "middle" | "end";
  above: boolean;
  text: string;
}

function placeLabels(
  inputs: readonly typeof majorAnnotations[number][],
): readonly PlacedLabel[] {
  const sorted = [...inputs].sort((a, b) => a.xRatio - b.xRatio);
  const laneRightEdge = LABEL_LANES.map(() => Number.NEGATIVE_INFINITY);
  const out: PlacedLabel[] = [];
  for (const a of sorted) {
    const text = abbreviateEventTitle(a.event.title);
    const width = text.length * LABEL_CHAR_WIDTH;
    const cx = padL + a.xRatio * plotW;
    const cy = yFor(a.value);
    // Default anchor: centre. Clamp the label horizontally so it doesn't run
    // off either edge — switch to start/end anchor when the label is right
    // up against the plot bounds.
    const halfWidth = width / 2;
    let labelX = cx;
    let anchor: "start" | "middle" | "end" = "middle";
    const minX = padL + 4;
    const maxX = padL + plotW - 4;
    if (cx - halfWidth < minX) {
      labelX = minX;
      anchor = "start";
    } else if (cx + halfWidth > maxX) {
      labelX = maxX;
      anchor = "end";
    }
    // Compute the horizontal extent the label will occupy given the anchor.
    const labelLeft = anchor === "start"
      ? labelX
      : anchor === "end"
        ? labelX - width
        : labelX - halfWidth;
    const labelRight = labelLeft + width;
    let assignedLane = -1;
    for (let i = 0; i < LABEL_LANES.length; i++) {
      if (labelLeft > laneRightEdge[i]! + LABEL_GAP_PX) {
        assignedLane = i;
        laneRightEdge[i] = labelRight;
        break;
      }
    }
    if (assignedLane === -1) continue; // dot stays; permanent label dropped
    const lane = LABEL_LANES[assignedLane]!;
    out.push({
      annotation: a,
      cx,
      cy,
      labelX,
      labelY: lane.y,
      anchor,
      above: lane.above,
      text,
    });
  }
  return out;
}

const placedLabels = placeLabels(majorAnnotations);

// Map TimelineCategory → CSS variable. Markers stay readable on the cream
// background and align with how the rest of the site colours each kind
// of event.
const CATEGORY_COLOUR: Record<TimelineCategory, string> = {
  fiscal: "var(--band-acute)",
  monetary: "var(--band-strain)",
  market: "var(--band-strain)",
  geopolitical: "var(--ink-0)",
  policy: "var(--accent)",
  delivery: "var(--accent)",
};
const CATEGORY_LABEL: Record<TimelineCategory, string> = {
  fiscal: "Fiscal",
  monetary: "Monetary",
  market: "Market",
  geopolitical: "Geopolitical",
  policy: "Policy",
  delivery: "Delivery",
};
function colourFor(category: TimelineCategory): string {
  return CATEGORY_COLOUR[category] ?? "var(--accent)";
}

// --- date ticks (sparse) --------------------------------------------------
// Render at most ~6 date labels so the x-axis stays readable. We pick the
// first, last, and a roughly-evenly-spaced set in between.
const dateTicks: { x: number; label: string }[] = [];
if (points.length > 0) {
  const TARGET_TICKS = Math.min(6, points.length);
  const step = points.length === 1 ? 1 : (points.length - 1) / (TARGET_TICKS - 1);
  for (let i = 0; i < TARGET_TICKS; i++) {
    const idx = Math.min(points.length - 1, Math.round(i * step));
    const x = points.length === 1 ? padL + plotW / 2 : padL + (idx / (points.length - 1)) * plotW;
    dateTicks.push({ x, label: shortDate(points[idx]!.timestamp) });
  }
}

// --- numeric ARIA summary -------------------------------------------------
const finite = headlineSeries.filter((n) => Number.isFinite(n));
const first = finite.length ? finite[0]! : null;
const last = finite.length ? finite[finite.length - 1]! : null;
const lo = finite.length ? Math.min(...finite) : null;
const hi = finite.length ? Math.max(...finite) : null;
function fmt(n: number): string {
  return Math.abs(n) >= 100 ? Math.round(n).toString() : n.toFixed(1);
}
const ariaSummary = first !== null && last !== null && lo !== null && hi !== null
  ? `Headline Tightrope Score over ${finite.length} day${finite.length === 1 ? "" : "s"}: starts ${fmt(first)}, ends ${fmt(last)}, range ${fmt(lo)} to ${fmt(hi)}. ${annotations.length} event${annotations.length === 1 ? "" : "s"} annotated.`
  : "Headline Tightrope Score over time — no data yet.";

// Stable IDs derived from chart dimensions so multiple charts on one page
// don't collide. Astro's slot-style scoping doesn't extend to SVG <defs>.
const idScope = `chart-${width}x${height}`;
---
<div class="annotated-chart" style={`--chart-accent: var(${accentBand.colourToken});`}>
  <svg
    class="chart-svg"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label={ariaSummary}
    preserveAspectRatio="none"
  >
    <defs>
      <linearGradient id={`fill-${idScope}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="var(--chart-accent)" stop-opacity="0.18" />
        <stop offset="1" stop-color="var(--chart-accent)" stop-opacity="0" />
      </linearGradient>
    </defs>

    {/* Band-tinted regions: subtle horizontal stripes mapping each band's range. */}
    {bandRegions.map((r) => (
      <rect
        x={padL}
        y={r.y}
        width={plotW}
        height={r.h}
        fill={`var(${r.colourToken})`}
        fill-opacity="0.05"
      />
    ))}

    {/* Y-axis grid lines + tick labels at band boundaries. */}
    <g class="grid">
      {yTicks.map((t) => (
        <line x1={padL} y1={t.y} x2={padL + plotW} y2={t.y} class="grid-line" />
      ))}
      {yTicks.map((t) => (
        <text x={padL - 8} y={t.y + 4} text-anchor="end" class="axis-label">{t.value}</text>
      ))}
    </g>

    {/* Optional pillar series — faint so the headline reads first. */}
    {pillarPaths.map((p) => (
      <path
        d={p.d}
        class={`pillar-line pillar-${p.id}`}
        fill="none"
        stroke-width="1"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    ))}

    {/* Headline fill + line. */}
    {headlineSeries.length > 1 ? (
      <path
        d={`${headlineD} L${(padL + plotW).toFixed(2)},${(padT + plotH).toFixed(2)} L${padL.toFixed(2)},${(padT + plotH).toFixed(2)} Z`}
        fill={`url(#fill-${idScope})`}
      />
    ) : null}
    <path
      d={headlineD}
      class="headline-line"
      fill="none"
      stroke="var(--chart-accent)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    {/* Event annotations. */}
    {annotations.map((a) => {
      const cx = padL + a.xRatio * plotW;
      const cy = yFor(a.value);
      const colour = colourFor(a.event.category);
      return (
        <g class="marker" tabindex="0" role="img" aria-label={`${a.event.title}, ${shortDate(a.event.date)}`}>
          {/* Vertical guide line from the data point down to the x-axis. */}
          <line
            x1={cx}
            y1={cy}
            x2={cx}
            y2={padT + plotH}
            class="marker-guide"
            stroke-dasharray="2 3"
          />
          {/* Invisible hit target. The visible dot stays at r=5 for visual
              density; this widens the actual tap area to the WCAG 2.5.8
              floor on touch devices. */}
          <circle cx={cx} cy={cy} r="14" class="marker-hit" />
          <circle cx={cx} cy={cy} r="5" fill={colour} class="marker-dot" />
          <circle cx={cx} cy={cy} r="2" fill="var(--bg-0)" class="marker-dot-inner" />
        </g>
      );
    })}

    {/* Permanent labels for major events (fiscal + geopolitical), packed
        into four lanes (two above plot, two below) by xRatio with greedy
        collision resolution. Labels that can't fit any lane are dropped —
        the marker dot still renders so the event remains hover-discoverable
        but the chart never collapses into overlapping text. */}
    {placedLabels.map((p) => {
      const colour = colourFor(p.annotation.event.category);
      const connectorY1 = p.above ? p.cy - 6 : p.cy + 6;
      const connectorY2 = p.above ? p.labelY + 4 : p.labelY - 10;
      return (
        <g class="event-label" aria-hidden="true">
          <line
            x1={p.cx}
            y1={connectorY1}
            x2={p.cx}
            y2={connectorY2}
            stroke={colour}
            stroke-width="1"
            stroke-opacity="0.7"
          />
          <text
            x={p.labelX}
            y={p.labelY}
            text-anchor={p.anchor}
            class="event-label-text"
            fill={colour}
          >{p.text}</text>
        </g>
      );
    })}

    {/* X-axis date ticks. data-tick-i lets the mobile CSS hide alternates
        without re-running the layout — at 6 ticks across an ~340px phone
        the labels overlap; on mobile we render only indices 0/2/4. */}
    {dateTicks.map((t, i) => (
      <text
        x={t.x}
        y={height - 10}
        text-anchor="middle"
        class="axis-label date-tick"
        data-tick-i={i}
      >{t.label}</text>
    ))}
  </svg>

  {/* Tooltips: one per marker. They're absolute-positioned siblings of the
      SVG so they can render outside the SVG's clipping rect. Anchored via
      the same xRatio used to place the marker. */}
  <div class="tooltip-layer" aria-hidden="true">
    {annotations.map((a) => {
      const leftPct = ((padL + a.xRatio * plotW) / width) * 100;
      const colour = colourFor(a.event.category);
      const summary = a.event.summary.length > 140 ? `${a.event.summary.slice(0, 137)}…` : a.event.summary;
      return (
        <div
          class="tooltip"
          data-event-id={a.event.id}
          style={`left: ${leftPct.toFixed(2)}%;`}
        >
          <div class="tooltip-head">
            <span class="tooltip-cat" style={`color: ${colour}; border-color: ${colour};`}>{CATEGORY_LABEL[a.event.category]}</span>
            <span class="tooltip-date">{shortDate(a.event.date)}</span>
          </div>
          <div class="tooltip-title">{a.event.title}</div>
          <div class="tooltip-summary">{summary}</div>
          <div class="tooltip-source">
            {/* SEC-6: a.event.sourceUrl is operator-curated in D1. Allowlist http(s). */}
            Source: {(() => {
              const href = safeHref(a.event.sourceUrl);
              return href
                ? <a href={href} target="_blank" rel="noopener">{a.event.sourceLabel} ↗</a>
                : <span>{a.event.sourceLabel}</span>;
            })()}
          </div>
        </div>
      );
    })}
  </div>
</div>

<style>
.annotated-chart {
  position: relative;
  width: 100%;
}
.chart-svg {
  width: 100%;
  height: auto;
  display: block;
  font-family: var(--font-mono);
}
.grid-line { stroke: var(--border-soft); stroke-width: 1; }
.axis-label { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-2); }
.headline-line { stroke: var(--chart-accent); }

/* Faint pillar series (only rendered when showPillars=true). */
.pillar-line { opacity: 0.45; }
.pillar-market { stroke: var(--band-strain); stroke-dasharray: 1 0; }
.pillar-fiscal { stroke: var(--band-acute); stroke-dasharray: 4 3; }
.pillar-labour { stroke: var(--accent-cool); stroke-dasharray: 6 3; }
.pillar-delivery { stroke: var(--ink-2); stroke-dasharray: 2 4; }

/* Permanent event labels (fiscal + geopolitical only). Hidden on small
   viewports so the chart stays legible — the hover-tooltip dot remains
   accessible. */
.event-label-text {
  font-family: var(--font-mono);
  font-size: 10.5px;
  font-weight: 500;
  letter-spacing: 0.02em;
  pointer-events: none;
  user-select: none;
}
@media (max-width: 600px) {
  /* Hide permanent labels on phones — at viewBox-scaled font sizes they
     render at ~4px CSS and become illegible. Markers stay tappable; the
     section-level "tap any dot" hint tells readers what to do. */
  .event-label { display: none; }
  /* Six date ticks crowd into ~340px of phone width; alternate odd
     indices so the remaining three (0/2/4) breathe. */
  .date-tick[data-tick-i="1"],
  .date-tick[data-tick-i="3"],
  .date-tick[data-tick-i="5"] { display: none; }
}

/* Markers — keyboard-focusable, with a soft halo on focus/hover. */
.marker { cursor: pointer; outline: none; }
.marker-hit {
  /* Invisible hit-target circle; widens the tap area on touch devices
     without bloating the visible dot. pointer-events:all ensures the
     transparent fill still receives taps/clicks. */
  fill: transparent;
  pointer-events: all;
}
.marker-guide {
  stroke: var(--ink-2);
  stroke-opacity: 0.18;
  stroke-width: 1;
  pointer-events: none;
  transition: stroke-opacity 140ms ease-out;
}
.marker:hover .marker-guide,
.marker:focus-visible .marker-guide,
.marker[data-pinned="true"] .marker-guide { stroke-opacity: 0.55; }
.marker-dot { transition: r 120ms ease-out; }
.marker:hover .marker-dot,
.marker:focus-visible .marker-dot,
.marker[data-pinned="true"] .marker-dot { r: 7; }
.marker:focus-visible,
.marker[data-pinned="true"] {
  /* SVG focus ring — outlines aren't reliable inside SVG, so we lean on
     the marker's own size change above plus a halo via filter. The pinned
     state shares the halo so a tap-pinned marker is visibly distinct from
     siblings even after the cursor / focus moves elsewhere. */
  filter: drop-shadow(0 0 4px var(--accent));
}

/* Tooltip layer is absolutely positioned over the SVG. Tooltips appear
   on marker hover/focus, and stay pinned on tap (handled by the JS shim
   below). They're hidden by default so they don't clutter the page on
   first paint. */
.tooltip-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.tooltip {
  position: absolute;
  top: 8px;
  /* `--tip-shift` is set by the JS shim post-activation to nudge the
     tooltip back inside the chart bounds when its anchor is near an
     edge. Defaults to 0 so SSR / no-JS still centres on the marker. */
  transform: translateX(calc(-50% + var(--tip-shift, 0px)));
  width: 240px;
  max-width: calc(100% - 16px);
  background: var(--bg-1);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  font-family: var(--font-sans);
  font-size: 12.5px;
  color: var(--ink-1);
  box-shadow: var(--shadow-md);
  opacity: 0;
  visibility: hidden;
  transition: opacity 140ms ease-out;
  pointer-events: none;
  z-index: 5;
}

/* The JS shim pairs each marker to its tooltip by DOM index and sets
   `data-active="true"` on hover, focus, or tap-to-pin. The tap-to-pin
   path also sets `data-pinned="true"` on the marker so the tooltip
   survives mouseleave; document-level click and Escape clear the pin.
   Without JS, the tooltip stays hidden but every event remains listed
   in the DOM with its title, summary and source link, so screen readers
   and crawlers still see the data. */
.tooltip[data-active="true"] {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
.tooltip-head { display: flex; gap: 8px; align-items: center; margin-bottom: 4px; }
.tooltip-cat {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
  border: 1px solid; border-radius: 999px; padding: 2px 7px;
}
.tooltip-date { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-2); }
.tooltip-title { font-family: var(--font-serif); font-size: 14px; color: var(--ink-0); margin-bottom: 4px; line-height: 1.3; }
.tooltip-summary { font-size: 12.5px; color: var(--ink-1); line-height: 1.45; margin-bottom: 6px; }
.tooltip-source { font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-2); }
.tooltip-source a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; }
.tooltip-source a:hover { color: var(--accent-dim); }

@media (max-width: 600px) {
  .tooltip { width: 220px; font-size: 12px; }
  /* Long summaries on a 220px tooltip can wrap to 5+ lines on phones,
     covering most of the chart. Cap at three lines visually — the full
     summary remains in the DOM for screen readers and copy-paste. */
  .tooltip-summary {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
}
</style>

<script is:inline nonce={Astro.locals.cspNonce}>
/**
 * Marker → tooltip wiring.
 *
 * Three behaviours:
 *   1. Hover / focus surfaces the matching tooltip transiently.
 *   2. Tap (click) on a marker pins its tooltip — survives mouseleave,
 *      survives focus moving away. Tap a different marker to switch the
 *      pin; tap outside any marker (or press Escape) to clear it.
 *   3. After activation, the tooltip's horizontal position is clamped
 *      so the 220–240px box never clips the chart edges on narrow
 *      viewports.
 *
 * We pair markers and tooltips by DOM index — the SSR template renders
 * them in matching order. Without this script the chart still renders;
 * tooltip content stays in the DOM behind opacity:0 so screen readers
 * and crawlers can still read every event.
 */
(() => {
  const charts = document.querySelectorAll(".annotated-chart");
  for (const chart of charts) {
    const markers = chart.querySelectorAll(".marker[aria-label]");
    const tooltips = chart.querySelectorAll(".tooltip[data-event-id]");
    if (!markers.length) continue;

    function clearAllActive() {
      tooltips.forEach((t) => { t.dataset.active = "false"; });
    }
    function clearAllPinned() {
      markers.forEach((m) => { m.dataset.pinned = "false"; });
    }
    function clampTooltip(tooltip) {
      // Reset shift, measure, then nudge horizontally so the tooltip stays
      // within the chart's bounding box. rAF lets the browser commit the
      // reset before we read the new bbox.
      tooltip.style.setProperty("--tip-shift", "0px");
      requestAnimationFrame(() => {
        const tipRect = tooltip.getBoundingClientRect();
        const chartRect = chart.getBoundingClientRect();
        const margin = 8;
        let shift = 0;
        if (tipRect.left < chartRect.left + margin) {
          shift = (chartRect.left + margin) - tipRect.left;
        } else if (tipRect.right > chartRect.right - margin) {
          shift = (chartRect.right - margin) - tipRect.right;
        }
        if (shift !== 0) tooltip.style.setProperty("--tip-shift", `${shift}px`);
      });
    }
    function activate(idx) {
      // Single-tooltip rule: only one is visible at a time.
      clearAllActive();
      const tooltip = tooltips[idx];
      if (!tooltip) return;
      tooltip.dataset.active = "true";
      clampTooltip(tooltip);
    }
    function deactivate(idx) {
      const tooltip = tooltips[idx];
      if (tooltip) tooltip.dataset.active = "false";
    }

    markers.forEach((marker, idx) => {
      marker.addEventListener("mouseenter", () => {
        if (marker.dataset.pinned === "true") return;
        activate(idx);
      });
      marker.addEventListener("mouseleave", () => {
        if (marker.dataset.pinned === "true") return;
        deactivate(idx);
      });
      marker.addEventListener("focus", () => activate(idx));
      marker.addEventListener("blur", () => {
        if (marker.dataset.pinned === "true") return;
        deactivate(idx);
      });
      // Tap-to-pin. stopPropagation prevents the document-level handler
      // below from immediately clearing the pin we just set.
      marker.addEventListener("click", (e) => {
        e.stopPropagation();
        const wasPinned = marker.dataset.pinned === "true";
        clearAllPinned();
        if (wasPinned) {
          deactivate(idx);
        } else {
          marker.dataset.pinned = "true";
          activate(idx);
        }
      });
    });

    // Outside-tap dismiss: any click outside a marker AND outside the
    // active tooltip clears the pin and hides the tooltip. The tooltip
    // exception is what lets readers click the "Source ↗" link without
    // the click immediately tearing down the tooltip they came from.
    // composedPath resolves SVG child elements (line, circles) to .marker.
    document.addEventListener("click", (e) => {
      const path = typeof e.composedPath === "function" ? e.composedPath() : [];
      const inside = path.some((n) => n && n.classList && (
        n.classList.contains("marker") || n.classList.contains("tooltip")
      ));
      if (inside) return;
      clearAllPinned();
      clearAllActive();
    });

    // Escape clears any pinned tooltip — keyboard users get the same
    // dismiss affordance as touch users.
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      clearAllPinned();
      clearAllActive();
    });

    // Re-clamp on resize / orientation change so a pinned tooltip that
    // sat fine in landscape doesn't suddenly clip in portrait.
    window.addEventListener("resize", () => {
      tooltips.forEach((t) => {
        if (t.dataset.active === "true") clampTooltip(t);
      });
    }, { passive: true });
  }
})();
</script>
