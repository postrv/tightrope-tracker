---
import { pathFromSeries } from "~/lib/format.js";

interface Axis {
  label: string;
  x: number;
  y: number;
}

interface Props {
  series: readonly number[];
  width?: number;
  height?: number;
  stroke?: string;
  /** Colour for the fill gradient under the line. Defaults to `stroke` so a
   * band-derived stroke (e.g. `var(--band-steady)`) flows through to the fill
   * without callers having to pass it twice. */
  fillColour?: string;
  fillGradientId?: string;
  ariaLabel?: string;
  gridLines?: number;
  minLabel?: string;
  maxLabel?: string;
  xTicks?: Axis[];
}

const {
  series,
  width = 600,
  height = 240,
  stroke = "var(--accent)",
  fillColour,
  fillGradientId,
  ariaLabel,
  gridLines = 4,
  minLabel,
  maxLabel,
  xTicks = [],
} = Astro.props;
const fillStop = fillColour ?? stroke;

const safeSeries = series && series.length ? series : [0, 0];
const padL = 40;
const padR = 20;
const padT = 20;
const padB = 30;
const plotW = width - padL - padR;
const plotH = height - padT - padB;

const d = pathFromSeries(
  safeSeries,
  plotW,
  plotH,
  1,
).replace(/([ML])([\d.]+),([\d.]+)/g, (_m, op, x, y) => `${op}${(Number(x) + padL).toFixed(2)},${(Number(y) + padT).toFixed(2)}`);

// Build fill path closing to baseline
let fillD = "";
if (fillGradientId && safeSeries.length > 1) {
  const first = `${padL},${padT + plotH}`;
  const last = `${padL + plotW},${padT + plotH}`;
  fillD = `M${first} ${d.replace(/^M/, "L")} L${last} Z`;
}

// Y axis gridlines
const gridYs = Array.from({ length: gridLines }, (_, i) => padT + (i / (gridLines - 1)) * plotH);

const minY = padT + plotH;
const maxY = padT;

// Numeric summary for screen readers and defensibility — includes
// first/last/min/max so a reader never has to interpret the SVG path.
const nums = series ? series.filter((n) => Number.isFinite(n)) : [];
const first = nums.length ? nums[0]! : null;
const last = nums.length ? nums[nums.length - 1]! : null;
const lo = nums.length ? Math.min(...nums) : null;
const hi = nums.length ? Math.max(...nums) : null;
function fmt(n: number): string {
  return Math.abs(n) >= 100 ? Math.round(n).toString() : n.toFixed(1);
}
const summary = first !== null && last !== null && lo !== null && hi !== null
  ? `starts ${fmt(first)}, ends ${fmt(last)}, range ${fmt(lo)} to ${fmt(hi)} over ${nums.length} point${nums.length === 1 ? "" : "s"}`
  : "no data";
const baseLabel = ariaLabel ?? "Line chart of time-series data";
const fullLabel = `${baseLabel}: ${summary}`;
---
<svg
  class="chart"
  viewBox={`0 0 ${width} ${height}`}
  preserveAspectRatio="none"
  role="img"
  aria-label={fullLabel}
>
  {fillGradientId ? (
    <defs>
      <linearGradient id={fillGradientId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color={fillStop} stop-opacity="0.22" />
        <stop offset="1" stop-color={fillStop} stop-opacity="0" />
      </linearGradient>
    </defs>
  ) : null}

  <g stroke="var(--border-soft)" stroke-width="1">
    {gridYs.map((y) => (
      <line x1={padL} y1={y} x2={padL + plotW} y2={y} />
    ))}
  </g>

  {maxLabel ? (
    <text x={padL - 8} y={maxY + 4} text-anchor="end" font-family="var(--font-mono)" font-size="10" fill="var(--ink-2)">{maxLabel}</text>
  ) : null}
  {minLabel ? (
    <text x={padL - 8} y={minY + 4} text-anchor="end" font-family="var(--font-mono)" font-size="10" fill="var(--ink-2)">{minLabel}</text>
  ) : null}

  {fillD ? <path d={fillD} fill={`url(#${fillGradientId})`} /> : null}

  <path d={d} stroke={stroke} stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />

  {xTicks.map((t) => (
    <text x={t.x} y={t.y} font-family="IBM Plex Mono" font-size="9.5" fill="var(--ink-2)">{t.label}</text>
  ))}
</svg>
