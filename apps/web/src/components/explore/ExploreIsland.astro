---
/**
 * Interactive "what-if" simulator. Server-side it renders a fully-functional
 * HTML skeleton populated with the live snapshot's values; client-side a
 * small vanilla-TS module wires the sliders, hash state, scenarios, baseline
 * lookups and live recompute. No UI framework is involved -- the work fits
 * comfortably in plain DOM APIs.
 *
 * Two normalisation modes (set in `whatIf.ts`):
 *   1. Empirical CDF (preferred). Used when the page-data loader passed
 *      a non-empty `baselines` map. Produces the same pressure score the
 *      live methodology would produce for any in-domain raw value.
 *   2. Linear fallback. Used per-indicator when a baseline summary is
 *      missing (e.g. delivery editorials with no historical series).
 *
 * The page footer transparently flags which mode is in effect for each
 * pillar so users can see when they're looking at "live methodology" vs
 * "approximate".
 */
import type { ScoreSnapshot, PillarId } from "@tightrope/shared";
import type { BaselineSummary } from "@tightrope/methodology";
import { PILLARS, PILLAR_ORDER, BANDS } from "@tightrope/shared";
import TightropeWalker from "../TightropeWalker.astro";
import IndicatorTooltip from "../IndicatorTooltip.astro";
import { LEVERS, liveValuesFromSnapshot } from "~/lib/whatIf.js";
import { safeJsonForScriptTag } from "~/lib/safeJson.js";

interface Props {
  snapshot: ScoreSnapshot;
  /** Per-indicator quantile summaries, keyed by indicator id. May be empty (cold-start). */
  baselines: Record<string, BaselineSummary>;
}

const { snapshot, baselines } = Astro.props;
const liveValues = liveValuesFromSnapshot(snapshot);
const headline = snapshot.headline;
const headlineRounded = Math.round(headline.value);
const initialBand = BANDS.find((b) => b.id === headline.band) ?? BANDS[0];

// Group levers by pillar in canonical pillar order.
const leversByPillar: Record<PillarId, typeof LEVERS[number][]> = {
  market: [],
  fiscal: [],
  labour: [],
  delivery: [],
};
for (const lever of LEVERS) leversByPillar[lever.pillar].push(lever);

// What share of each pillar's levers have an ECDF baseline summary?
// Drives the per-pillar mode disclosure in the footer.
const pillarEcdfCoverage: Record<PillarId, { ecdf: number; linear: number }> = {
  market: { ecdf: 0, linear: 0 },
  fiscal: { ecdf: 0, linear: 0 },
  labour: { ecdf: 0, linear: 0 },
  delivery: { ecdf: 0, linear: 0 },
};
for (const lever of LEVERS) {
  const summary = baselines[lever.indicatorId];
  const present = summary && summary.knots.length > 0;
  if (present) pillarEcdfCoverage[lever.pillar].ecdf++;
  else pillarEcdfCoverage[lever.pillar].linear++;
}
const ecdfTotal = Object.values(pillarEcdfCoverage).reduce((a, p) => a + p.ecdf, 0);
const allEcdf = ecdfTotal === LEVERS.length;
const partialEcdf = ecdfTotal > 0 && ecdfTotal < LEVERS.length;
---
<section
  class="explore-root"
  data-explore-root
  aria-label="What-if scenario explorer"
>
  <div class="container">
    <header class="explore-head">
      <span class="eyebrow">Scenario simulator · {LEVERS.length} levers · {allEcdf ? "live ECDF methodology" : partialEcdf ? "partial ECDF coverage" : "linear approximation"}</span>
      <h1>what if&hellip;<span class="lfg-u">?</span></h1>
      <p class="lede">
        Move the sliders to see what the headline score would read <em>if</em> these values had been observed today.
        Each lever is a real headline driver, scored through the same empirical-CDF baseline the live score uses.
        <strong>This is a counterfactual recomputation, not a forecast.</strong>
        Share your scenario with the link at the bottom.
      </p>
      <noscript>
        <p class="noscript-note">
          The simulator needs JavaScript to drag the sliders. The figures above show today's live snapshot — visit in a JS-enabled browser to play with scenarios.
        </p>
      </noscript>

      <div class="scenario-row" role="toolbar" aria-label="Pre-baked scenarios">
        <button type="button" data-scenario="live" aria-pressed="true">Live now</button>
        <button type="button" data-scenario="spring2025">Spring 2025 crunch</button>
        <button type="button" data-scenario="conflict">Conflict shock</button>
        <button type="button" data-scenario="recovery">Recovery</button>
        <button type="button" data-scenario="crisis">2008-style crisis</button>
        <button type="button" class="reset" data-action="reset">Reset to live</button>
      </div>
      <p class="scenario-blurb" data-scenario-blurb>
        The current snapshot, untouched. Move any slider to start exploring.
      </p>

      {partialEcdf || (!allEcdf && !partialEcdf) ? (
        <p class="fallback-banner" role="status">
          {!allEcdf && !partialEcdf ? (
            <>
              <strong>Approximation in effect.</strong> No baseline data available right now — every slider falls back to a linear remap of its domain to a 0–100 pressure score. Refresh in a minute to retry the live methodology, or read the <a href="/methodology">methodology</a> for what changes when ECDF is unavailable.
            </>
          ) : (
            <>
              <strong>Partial coverage.</strong> Some sliders are running on a linear approximation rather than the live empirical CDF — look for the <code>linear</code> badge next to a slider's range note. Levers tagged <code>ECDF</code> use the live methodology; the others fall back to a linear remap of the slider domain.
            </>
          )}
        </p>
      ) : null}
    </header>

    <div class="explore-grid">
      <div class="panel slider-panel" aria-labelledby="slider-heading">
        <h2 id="slider-heading" class="panel-title">Drivers — by pillar</h2>
        {PILLAR_ORDER.map((pillarId) => {
          const def = PILLARS[pillarId];
          const pillarLevers = leversByPillar[pillarId];
          if (pillarLevers.length === 0) return null;
          return (
            <fieldset class="pillar-group" data-pillar-group={pillarId}>
              <legend class="pillar-group-legend">
                <span class="pillar-group-name">{def.title}</span>
                <span class="pillar-group-count">{pillarLevers.length} {pillarLevers.length === 1 ? "lever" : "levers"} · weight {Math.round(def.weight * 100)}%</span>
              </legend>
              <ul class="lever-list">
                {pillarLevers.map((lever) => {
                  const live = liveValues[lever.key];
                  const hasBaseline = !!(baselines[lever.indicatorId] && baselines[lever.indicatorId]!.knots.length > 0);
                  return (
                    <li class="lever" data-lever={lever.key}>
                      <div class="lever-head">
                        <label for={`lever-${lever.key}`} class="lever-label">
                          <IndicatorTooltip label={lever.label} indicatorId={lever.indicatorId} tipId={`tip-lever-${lever.key}`} />
                        </label>
                        <span class="lever-value" data-lever-display>{lever.format(live)}</span>
                      </div>
                      <div class="lever-controls">
                        <input
                          id={`lever-${lever.key}`}
                          type="range"
                          min={lever.min}
                          max={lever.max}
                          step={lever.step}
                          value={live}
                          data-lever-range
                          aria-valuemin={lever.min}
                          aria-valuemax={lever.max}
                          aria-valuenow={live}
                          aria-valuetext={lever.format(live)}
                          aria-describedby={`lever-${lever.key}-meta`}
                        />
                        <input
                          type="number"
                          min={lever.min}
                          max={lever.max}
                          step={lever.step}
                          value={live}
                          data-lever-number
                          aria-label={`${lever.label} numeric input`}
                        />
                      </div>
                      <div class="lever-meta" id={`lever-${lever.key}-meta`}>
                        <span class="range-note">
                          {lever.format(lever.min)} &mdash; {lever.format(lever.max)}
                        </span>
                        <span class={`mode-badge ${hasBaseline ? "ecdf" : "linear"}`} title={hasBaseline ? "Empirical CDF — live methodology" : "Linear approximation — no baseline available"}>
                          {hasBaseline ? "ECDF" : "linear"}
                        </span>
                        <button
                          type="button"
                          class="reset-live"
                          data-lever-reset-live
                          data-live-value={live}
                        >
                          live: {lever.format(live)}
                        </button>
                      </div>
                      <div class="lever-effect" data-lever-effect aria-hidden="true">&nbsp;</div>
                    </li>
                  );
                })}
              </ul>
            </fieldset>
          );
        })}
        <p class="methodology-note">
          {allEcdf ? (
            <>Every lever is normalised through the live empirical CDF over the 2019&ndash;present baseline (excluding the 2020 COVID outlier window). Untouched indicators stay at their live values; the headline still uses the production weighted-geometric-mean aggregation. <a href="/methodology">Read the full methodology &rarr;</a></>
          ) : partialEcdf ? (
            <>Levers tagged ECDF use the live empirical-CDF baseline; levers tagged "linear" fall back to a linear remap of the slider range to a 0&ndash;100 pressure score (no baseline available). Untouched indicators stay at their live values; the headline still uses the production weighted-geometric-mean aggregation. <a href="/methodology">Read the full methodology &rarr;</a></>
          ) : (
            <>The page-data loader did not return baselines on this request, so each lever falls back to a linear remap of its slider range. Refresh in 60s to retry the API. <a href="/methodology">Read the full methodology &rarr;</a></>
          )}
        </p>
      </div>

      <div class="panel readout-panel" aria-labelledby="readout-heading">
        <h2 id="readout-heading" class="panel-title">Scenario score</h2>
        <div class="readout-card" data-readout-card style={`--band-colour: var(${initialBand.colourToken});`}>
          <div class="readout-score">
            <div class="score-num" aria-live="polite">
              <span class="score-value" data-headline-value>{headlineRounded}</span><span class="sub">/100</span>
            </div>
            <div class="score-meta">
              <span class="band-pill" data-band-pill style={`color: var(${initialBand.colourToken}); border-color: var(${initialBand.colourToken}); background: color-mix(in srgb, var(${initialBand.colourToken}) 12%, transparent);`}>{initialBand.label}</span>
              <span class="band-label" data-band-label>{initialBand.editorialLabel}</span>
            </div>
            <div class="vs-live" data-vs-live aria-live="polite">
              <span class="vs-live-arrow">&middot;</span>
              <span class="vs-live-text">Matches live</span>
            </div>
          </div>
          <div class="readout-walker" data-readout-walker>
            <TightropeWalker score={headlineRounded} animate={false} />
          </div>
        </div>

        <ul class="pillar-tiles" aria-label="Pillar scores">
          {PILLAR_ORDER.map((id) => {
            const p = snapshot.pillars[id];
            const valueRounded = Math.round(p.value);
            const def = PILLARS[id];
            return (
              <li class="pillar-tile" data-pillar={id} data-live-value={p.value.toFixed(1)}>
                <span class="pillar-tile-label">{def.shortTitle}</span>
                <span class="pillar-tile-value" data-pillar-value>{valueRounded}</span>
                <div class="pillar-tile-bar" aria-hidden="true">
                  <span class="pillar-tile-bar-live" data-pillar-bar-live style={`width: ${p.value}%;`}></span>
                  <span class="pillar-tile-bar-scenario" data-pillar-bar-scenario style={`width: ${p.value}%;`}></span>
                </div>
                <span class="pillar-tile-delta" data-pillar-delta>matches live</span>
                <span class="pillar-tile-weight">weight {Math.round(def.weight * 100)}%</span>
              </li>
            );
          })}
        </ul>

        <div class="dominant-row">
          <span class="dominant-label">Dominant pillar:</span>
          <span data-dominant-pillar>{PILLARS[headline.dominantPillar].title}</span>
        </div>

        <div class="share-row">
          <button type="button" class="share-btn" data-action="share">Copy share link</button>
          <span class="share-status" data-share-status role="status" aria-live="polite"></span>
        </div>

        <p class="methodology-foot">
          <a href="#methodology">Methodology footer</a> &middot; <a href="/methodology">Full methodology</a>
        </p>
      </div>
    </div>

    <footer id="methodology" class="explore-foot">
      <p>
        <strong>How it works.</strong> The headline score is recomputed in your
        browser using the same weighted-geometric-mean aggregation as the live
        homepage. Each slider is normalised through the same empirical-CDF
        baseline the production score uses (where available). Other indicators
        in the same pillar stay at their live values, so a single lever's
        effect is bounded by its in-pillar weight. Untouched pillars are
        returned verbatim from the live snapshot. The 1d/30d/YTD deltas reset
        to zero once you move a slider &mdash; they compare to live history,
        which a hypothetical scenario isn't.
      </p>
    </footer>
  </div>
</section>

<!--
  Initial state for the client island. SEC-5: the payload includes
  operator-curated strings from D1 (indicator notes etc.); plain
  JSON.stringify into set:html would let a string containing '</script>'
  terminate this tag and DOM-XSS the page. `safeJsonForScriptTag` escapes
  HTML-sensitive characters to their `\uXXXX` JSON escapes — JSON.parse
  recovers the original bytes.
-->
<script
  type="application/json"
  data-explore-config
  set:html={safeJsonForScriptTag({
    live: liveValues,
    pillars: Object.fromEntries(PILLAR_ORDER.map((id) => [id, snapshot.pillars[id].value])),
    snapshot,
    baselines,
  })}
></script>

<style>
  .explore-root {
    padding: 56px 0 80px;
    border-bottom: 1px solid var(--border-soft);
  }

  .explore-head { max-width: 760px; }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--ink-2);
    text-transform: uppercase;
  }
  h1 {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 18px 0 16px;
  }
  .lede {
    color: var(--ink-1);
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 580px;
  }
  .lede em { font-style: italic; color: var(--ink-0); }
  .lede strong { font-weight: 500; color: var(--ink-0); }
  .noscript-note {
    margin: 0 0 24px;
    padding: 12px 16px;
    border-left: 2px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    font-size: 13.5px;
    color: var(--ink-1);
  }

  .scenario-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .scenario-row button {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    background: var(--bg-1);
    color: var(--ink-1);
    border-radius: 999px;
    padding: 7px 14px;
    cursor: pointer;
    transition: border-color 120ms, background 120ms, color 120ms;
  }
  .scenario-row button:hover,
  .scenario-row button:focus-visible {
    border-color: var(--accent);
    color: var(--ink-0);
    outline: none;
  }
  .scenario-row button[aria-pressed="true"] {
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    border-color: var(--accent);
    color: var(--ink-0);
  }
  .scenario-row .reset { margin-left: auto; }
  /* Resting state: the user is at live — reset has nothing to do. */
  .scenario-row .reset {
    opacity: 0.55;
    pointer-events: none;
  }
  /* Active state: any override is live -- the reset is now meaningful. */
  .scenario-row .reset.is-active {
    opacity: 1;
    pointer-events: auto;
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    border-color: var(--accent);
    color: var(--ink-0);
    font-weight: 600;
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 40%, transparent);
    animation: reset-pulse 2.4s ease-out infinite;
  }
  .scenario-row .reset.is-active::before {
    content: "↺ ";
    margin-right: 4px;
  }
  @keyframes reset-pulse {
    0%   { box-shadow: 0 0 0 0   color-mix(in srgb, var(--accent) 50%, transparent); }
    70%  { box-shadow: 0 0 0 6px color-mix(in srgb, var(--accent)  0%, transparent); }
    100% { box-shadow: 0 0 0 0   color-mix(in srgb, var(--accent)  0%, transparent); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scenario-row .reset.is-active { animation: none; }
  }
  .scenario-blurb {
    margin: 0 0 36px;
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-1);
    font-size: 14.5px;
    max-width: 600px;
  }

  .fallback-banner {
    margin: 0 0 28px;
    padding: 12px 16px;
    border-left: 3px solid var(--band-strain, var(--accent));
    background: color-mix(in srgb, var(--band-strain, var(--accent)) 8%, transparent);
    color: var(--ink-1);
    font-size: 13.5px;
    line-height: 1.55;
    border-radius: 0 6px 6px 0;
  }
  .fallback-banner strong { color: var(--ink-0); font-weight: 600; }
  .fallback-banner code {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 1px 6px;
    border-radius: 3px;
    background: color-mix(in srgb, var(--ink-2) 10%, transparent);
  }
  .fallback-banner a { color: var(--accent); }

  .explore-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 920px) {
    .explore-grid { grid-template-columns: 1fr; gap: 24px; }
  }

  .panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-1);
    padding: 28px 28px 24px;
  }
  .panel-title {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--ink-2);
    text-transform: uppercase;
    margin: 0 0 18px;
  }

  .pillar-group {
    border: 0;
    margin: 0 0 22px;
    padding: 0;
  }
  .pillar-group-legend {
    display: flex;
    align-items: baseline;
    gap: 12px;
    width: 100%;
    padding: 0 0 8px;
    border-bottom: 1px dashed var(--border);
    margin-bottom: 14px;
  }
  .pillar-group-name {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    color: var(--ink-0);
  }
  .pillar-group-count {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-2);
    text-transform: uppercase;
    margin-left: auto;
  }

  .lever-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 18px; }
  .lever-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 8px; }
  .lever-label {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--ink-0);
    font-weight: 500;
  }
  .lever-value {
    font-family: var(--font-mono);
    font-size: 13.5px;
    color: var(--ink-0);
    font-variant-numeric: tabular-nums;
  }

  .lever-controls {
    display: grid;
    grid-template-columns: 1fr 96px;
    gap: 12px;
    align-items: center;
  }
  .lever-controls input[type="range"] {
    width: 100%;
    accent-color: var(--accent, #FE5500);
  }
  .lever-controls input[type="range"]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }
  .lever-controls input[type="number"] {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg-0);
    color: var(--ink-0);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 8px;
    width: 100%;
  }
  .lever-controls input[type="number"]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .lever-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
    letter-spacing: 0.04em;
  }
  .mode-badge {
    font-size: 9.5px;
    letter-spacing: 0.12em;
    padding: 2px 7px;
    border-radius: 999px;
    border: 1px solid var(--border);
    text-transform: uppercase;
  }
  .mode-badge.ecdf {
    color: var(--ink-1);
    border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
  }
  .mode-badge.linear {
    color: var(--ink-2);
  }
  .reset-live {
    background: none;
    border: 0;
    color: var(--ink-2);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    padding: 0;
    text-decoration: underline dotted;
    text-underline-offset: 3px;
  }
  .reset-live:hover, .reset-live:focus-visible {
    color: var(--accent);
    outline: none;
  }
  /* Lit when this specific lever differs from live; clear when at live. */
  .reset-live.is-active {
    color: var(--accent);
    text-decoration-style: solid;
    font-weight: 600;
  }
  .reset-live.is-active::before {
    content: "↺ ";
  }
  .lever-effect {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-2);
    height: 14px;
    transition: color 240ms;
  }
  .lever-effect.up { color: var(--band-acute); }
  .lever-effect.dn { color: var(--band-slack); }

  .methodology-note {
    margin: 22px 0 0;
    padding-top: 16px;
    border-top: 1px dashed var(--border);
    font-size: 12.5px;
    color: var(--ink-2);
    line-height: 1.55;
  }
  .methodology-note a { color: var(--accent); }

  /* ---- READOUT ---- */
  .readout-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: center;
    padding: 22px 24px;
    background: var(--bg-0);
    border: 1px solid var(--border);
    border-radius: 10px;
    position: relative;
    overflow: hidden;
  }
  .readout-card::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: var(--band-colour, var(--band-acute));
    transition: background 240ms;
  }
  .score-num {
    font-family: var(--font-mono);
    font-size: 64px;
    font-weight: 500;
    line-height: 1;
    color: var(--ink-0);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  .score-num .sub { font-size: 18px; color: var(--ink-2); font-weight: 400; }
  .score-meta { display: flex; flex-direction: column; gap: 6px; margin-top: 10px; }
  .band-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    align-self: flex-start;
    border: 1px solid;
