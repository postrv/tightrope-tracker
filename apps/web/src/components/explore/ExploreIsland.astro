<script>
  /**
   * Thin wiring shim. The real bootstrap lives in `~/lib/exploreBootstrap.ts`
   * so it can be unit-tested under happy-dom without parsing this .astro file.
   */
  import { bootstrapExplore, type ExploreConfig } from "~/lib/exploreBootstrap.js";

  const root = document.querySelector<HTMLElement>("[data-explore-root]");
  const configEl = document.querySelector<HTMLScriptElement>("[data-explore-config]");
  if (root && configEl?.textContent) {
    const config = JSON.parse(configEl.textContent) as ExploreConfig;
    bootstrapExplore(root, config);
  }
