---
import "~/styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalPath?: string;
  /** Kept for API compatibility; CSP now lives in _headers, per-route. */
  embed?: boolean;
}

const {
  title,
  description = "A live, transparent accountability dashboard mapping the real constraints on the UK Government's growth agenda.",
  ogImage = "/og/headline-score.png",
  canonicalPath,
  embed = false,
} = Astro.props;

// Content Security Policy is served via HTTP response headers (see
// apps/web/public/_headers). `frame-ancestors` in a <meta> tag is silently
// ignored by browsers, so it must live on the response. Per-route rules
// (embed vs. non-embed) are handled there too. `embed` is kept as a prop
// for backwards compatibility with callers and to suppress Plausible below.

const canonical = canonicalPath
  ? new URL(canonicalPath, Astro.site ?? "https://tightropetracker.uk").toString()
  : Astro.url.toString();

const ogImageUrl = ogImage.startsWith("/og/")
  ? `https://og.tightropetracker.uk${ogImage}`
  : new URL(ogImage, Astro.site ?? "https://tightropetracker.uk").toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@tightropetracker" />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;0,9..40,900;1,9..40,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon: LFG brand mark (concentric orange/cream/teal arcs).
         Source asset: https://lookingforgrowth.uk/ favicon.
         PNG is primary so the polished raster LFG mark renders in all
         browsers and mobile home-screens. -->
    <link rel="icon" type="image/png" sizes="178x178" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <meta name="theme-color" content="#EBE3D0" />

    {/*
      SEC-12: Plausible script self-hosted under /vendor/plausible.js.
      Their CDN rotates aggressively, so a Subresource-Integrity hash
      pinned against `plausible.io/js/script.js` would break analytics
      every few weeks; self-hosting eliminates that maintenance burden,
      removes a third-party origin from `script-src`, and lets the
      browser cache it alongside the rest of the page bundle. Events
      still POST to plausible.io via the `data-api` attribute, allowed
      by `connect-src https://plausible.io`. To refresh the bundled
      script when Plausible ships an upgrade:
        curl -sLO https://plausible.io/js/script.js
        mv script.js apps/web/public/vendor/plausible.js
      Bundled version: Plausible v33 (data-v inside the script body).
    */}
    {embed ? null : (
      <script
        defer
        is:inline
        nonce={Astro.locals.cspNonce}
        data-domain="tightropetracker.uk"
        data-api="https://plausible.io/api/event"
        src="/vendor/plausible.js"
      ></script>
    )}
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <slot />
  </body>
</html>

<script is:inline nonce={Astro.locals.cspNonce}>
  // Default to LFG light/cream; allow user override to dark via localStorage.
  try {
    const pref = localStorage.getItem("tightrope-theme");
    if (pref === "dark") document.documentElement.classList.add("dark");
  } catch (e) { /* ignore */ }
</script>
