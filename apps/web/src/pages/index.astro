---
import BaseLayout from "~/layouts/BaseLayout.astro";
import TopNav from "~/components/TopNav.astro";
import Hero from "~/components/Hero.astro";
import HeadlineChartSection from "~/components/HeadlineChartSection.astro";
import PillarStrip from "~/components/PillarStrip.astro";
import TodayStrip from "~/components/TodayStrip.astro";
import MarketSection from "~/components/MarketSection.astro";
import FiscalSection from "~/components/FiscalSection.astro";
import LabourSection from "~/components/LabourSection.astro";
import DeliverySection from "~/components/DeliverySection.astro";
import Timeline from "~/components/Timeline.astro";
import ShareGrid from "~/components/ShareGrid.astro";
import ActionSection from "~/components/ActionSection.astro";
import SiteFooter from "~/components/SiteFooter.astro";
import { loadHomepageData } from "~/lib/page-data.js";

const data = await loadHomepageData(Astro.locals);
const { snapshot, movements, delivery, timeline, history, empty } = data;
const isStale = Boolean(snapshot.headline.stale);
// Figure out which pillars specifically are stale so the banner can name them
// instead of making the reader hunt across the page.
const stalePillarLabels = Object.values(snapshot.pillars)
  .filter((p) => p.stale)
  .map((p) => p.pillar);

// Source-health: upstream feeds whose latest ingestion attempt did not
// succeed. Surfaces the "BoE is broken" case before the 2d/7d staleness
// thresholds -- data is still within its freshness window but we want the
// reader to know a feed is silently running on carry-forward values.
const failingSources = snapshot.sourceHealth ?? [];
const failingSourceNames = failingSources.map((s) => s.name);
const showSourceWarning = !isStale && !empty && failingSources.length > 0;
---
<BaseLayout title="Tightrope Tracker — a live dashboard of UK economic constraint">
  <TopNav band={snapshot.headline.band} updatedAt={snapshot.headline.updatedAt} stale={isStale} />
  <main id="main">
    {empty ? (
      <div class="stale-banner container" role="status">
        Data loading — the first ingestion run hasn't completed. Some figures on this page are placeholders and will update automatically.
      </div>
    ) : isStale ? (
      <div class="stale-banner stale container" role="status">
        <strong>Showing last-known values.</strong> One or more inputs haven't refreshed in their usual window ({stalePillarLabels.join(", ")}). The figures below are carry-forward readings, not live prints — we'll clear this banner automatically as fresh data arrives.
        {failingSources.length > 0 ? (
          <span class="source-note"> Upstream feeds affected: {failingSourceNames.join(", ")}.</span>
        ) : null}
      </div>
    ) : showSourceWarning ? (
      <div class="stale-banner warn container" role="status">
        <strong>Upstream feed{failingSources.length === 1 ? "" : "s"} failing.</strong> {failingSourceNames.join(", ")} {failingSources.length === 1 ? "hasn't" : "haven't"} ingested successfully on {failingSources.length === 1 ? "its" : "their"} last run. The figures below are still within their freshness window — we're showing the last good readings and will clear this banner as soon as ingestion recovers.
      </div>
    ) : null}

    <Hero headline={snapshot.headline} />
    <HeadlineChartSection history={history} events={timeline} />
    <PillarStrip pillars={snapshot.pillars} />
    <TodayStrip movements={movements} />
    <MarketSection pillar={snapshot.pillars.market} movements={movements} />
    <FiscalSection pillar={snapshot.pillars.fiscal} />
    <LabourSection pillar={snapshot.pillars.labour} />
    <DeliverySection commitments={delivery} pillar={snapshot.pillars.delivery} />
    <Timeline events={timeline} />
    <section class="explore-cta" aria-labelledby="explore-cta-heading">
      <div class="container">
        <div class="explore-cta-card">
          <div>
            <span class="eyebrow">interactive · 14 levers · live methodology</span>
            <h2 id="explore-cta-heading">what if&hellip;<span class="lfg-u">?</span></h2>
            <p>
              Drag any of the 14 headline drivers — gilt yields, pay growth, headroom, housing — and watch the score, pillars, and band recompute through the same empirical-CDF baseline the live methodology uses. <strong>Counterfactual, not a forecast.</strong>
            </p>
          </div>
          <a class="explore-cta-btn" href="/explore">Try the simulator →</a>
        </div>
      </div>
    </section>
    <ShareGrid snapshot={snapshot} movements={movements} delivery={delivery} />
    <ActionSection headline={snapshot.headline} />
  </main>
  <SiteFooter updatedAt={snapshot.headline.updatedAt} stale={isStale} />
</BaseLayout>

<style>
.explore-cta {
  padding: 36px 0 16px;
}
.explore-cta-card {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 28px;
  align-items: center;
  padding: 28px 32px;
  border: 1px solid var(--border);
  border-radius: 14px;
  background: linear-gradient(135deg,
    color-mix(in srgb, var(--accent) 6%, var(--bg-1)) 0%,
    var(--bg-1) 70%);
}
.explore-cta-card .eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.16em;
  color: var(--ink-2);
  text-transform: uppercase;
}
.explore-cta-card h2 {
  font-family: var(--font-serif);
  font-weight: 700;
  font-size: clamp(28px, 3vw, 38px);
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 12px 0 10px;
  color: var(--ink-0);
}
.explore-cta-card p {
  margin: 0;
  color: var(--ink-1);
  font-size: 15px;
  line-height: 1.55;
  max-width: 640px;
}
.explore-cta-card p strong { color: var(--ink-0); font-weight: 500; }
.explore-cta-btn {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 12px 22px;
  border: 1px solid var(--accent);
  border-radius: 999px;
  background: color-mix(in srgb, var(--accent) 14%, transparent);
  color: var(--ink-0);
  transition: background 200ms;
}
.explore-cta-btn:hover, .explore-cta-btn:focus-visible {
  background: color-mix(in srgb, var(--accent) 28%, transparent);
  outline: none;
}
@media (max-width: 720px) {
  .explore-cta-card { grid-template-columns: 1fr; }
}

.stale-banner {
  margin-top: 14px;
  padding: 14px 22px;
  border-left: 3px solid var(--accent-dim);
  background: color-mix(in srgb, var(--accent) 6%, transparent);
  color: var(--ink-1);
  font-family: var(--font-mono);
  font-size: 12px;
  border-radius: 0 8px 8px 0;
}
.stale-banner.stale {
  border-left-color: var(--band-critical);
  background: color-mix(in srgb, var(--band-critical) 8%, transparent);
  color: var(--ink-0);
}
.stale-banner.stale strong { color: var(--band-critical); font-family: inherit; font-weight: 600; }
.stale-banner.warn {
  border-left-color: var(--band-strain, var(--accent));
  background: color-mix(in srgb, var(--band-strain, var(--accent)) 8%, transparent);
  color: var(--ink-0);
}
.stale-banner.warn strong { color: var(--band-strain, var(--accent)); font-family: inherit; font-weight: 600; }
.stale-banner .source-note { color: var(--ink-1); margin-left: 4px; }
</style>
